---
// RecentArticles.astro
// Exibe artigos recentes do blog — excluindo o artigo atual.
// Usar no final de reviews e guias para aumentar pageviews e linkagem interna.

import { getRecentArticles, formatDate } from '../lib/articles.ts';
import type { ArticleCategory } from '../lib/articles.ts';

interface Props {
  excludeSlug?: string;
  limit?: number;
  title?: string;
}

const { excludeSlug, limit = 4, title = 'Artigos Relacionados' } = Astro.props;
const articles = getRecentArticles(excludeSlug, limit);

const categoryColors: Record<ArticleCategory, string> = {
  Review: 'bg-blue-500/10 text-blue-600 border-blue-500/20',
  Guia: 'bg-emerald-500/10 text-emerald-600 border-emerald-500/20',
  Comparativo: 'bg-violet-500/10 text-violet-600 border-violet-500/20',
  Lista: 'bg-amber-500/10 text-amber-600 border-amber-500/20',
};
---

<section class="mx-auto max-w-4xl px-4 py-12" aria-label={title}>
  <div class="flex items-center gap-3 mb-6">
    <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-primary/10">
      <svg class="h-4 w-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/>
      </svg>
    </div>
    <h2 class="text-lg font-black text-foreground">{title}</h2>
  </div>

  <div class="grid gap-4 sm:grid-cols-2">
    {articles.map((article) => (
      <a
        href={article.slug}
        class="group flex gap-4 rounded-2xl border border-border bg-card p-4 hover:border-primary/30 hover:shadow-sm transition-all"
      >
        <div class="flex-shrink-0 w-20 h-20 rounded-xl bg-secondary/30 flex items-center justify-center overflow-hidden">
          <img
            src={article.image}
            alt={`${article.title} — preview`}
            width="80"
            height="80"
            class="w-full h-full object-contain group-hover:scale-105 transition-transform duration-300"
            loading="lazy"
          />
        </div>
        <div class="flex flex-col justify-center min-w-0 gap-1">
          <span class={`self-start rounded-full border px-2 py-0.5 text-[10px] font-bold ${categoryColors[article.category]}`}>
            {article.category}
          </span>
          <h3 class="text-sm font-bold text-foreground leading-snug group-hover:text-primary transition-colors line-clamp-2">
            {article.title}
          </h3>
          <p class="text-[11px] text-muted-foreground">{formatDate(article.updatedDate ?? article.date)}</p>
        </div>
      </a>
    ))}
  </div>

  <div class="mt-6 text-center">
    <a href="/blog/" class="inline-flex items-center gap-1.5 text-sm font-semibold text-primary hover:underline transition-colors">
      Ver todos os artigos do Blog
      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
    </a>
  </div>
</section>
