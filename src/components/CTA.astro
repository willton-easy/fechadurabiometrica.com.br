---
// ============================================================
// ARQUIVO: src/components/CTA.astro
// O QUE FAZ: Este é o "Botão de Chamada para Ação" (CTA = Call To Action).
// É aquele botão azul que aparece nos artigos com texto como
// "Ver Preço Promocional" e leva o usuário para comprar o produto.
//
// Como funciona: você passa um "link" e ele cria o botão.
// Opcionalmente pode passar um "texto" personalizado para o botão
// e um "priceText" (texto de preço) que aparece em cinza embaixo.
// ============================================================

// Definição das propriedades que o componente pode receber.
// O '?' indica que o campo é opcional.
interface Props {
  link: string; // 'link' é obrigatório: o endereço de destino do botão
  text?: string; // 'text' é opcional: o texto exibido no botão
  priceText?: string; // 'priceText' é opcional: texinho em cinza abaixo do botão
}

// Aqui "desestruturamos" (pegamos) as propriedades passadas de fora.
// Se 'text' não foi informado, usamos "Ver Preço Promocional" como padrão.
const { link, text = "Ver Preço Promocional", priceText } = Astro.props;
---

{/* Caixa centralizadora em volta do botão */}
<div class="my-8 text-center flex flex-col items-center justify-center gap-2">
  {
    /*
    O botão em si — é um link <a> que abre em nova aba (target="_blank").
    rel="noopener"  → segurança: impede que a nova aba acesse esta página
    rel="nofollow"  → diz ao Google para não seguir este link
    rel="sponsored" → avisa ao Google que é um link patrocinado (afiliado)
  */
  }
  <a
    href={link}
    target="_blank"
    rel="noopener nofollow sponsored"
    class="inline-flex items-center justify-center bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-8 rounded-lg shadow-md transition-transform hover:-translate-y-1 w-full sm:w-auto"
  >
    {/* Texto do botão (ex: "Ver Preço Promocional") */}
    {text}

    {/* Ícone de "abrir em nova janela" ao lado do texto */}
    <svg
      class="w-5 h-5 ml-2"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
      ></path>
    </svg>
  </a>

  {
    /*
    Se 'priceText' foi fornecido, mostra o texto de preço abaixo do botão.
    O '&&' funciona como "SE ... ENTÃO ...":
    SE priceText existir → ENTÃO mostra o <p>.
  */
  }
  {priceText && <p class="text-xs text-neutral-500">{priceText}</p>}
</div>
