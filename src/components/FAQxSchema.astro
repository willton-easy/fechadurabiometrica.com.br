---
// src/components/FAQxSchema.astro
// Este componente recebe uma lista de FAQs e renderiza:
// 1. O visual em HTML (Acordeão) para o usuário ler.
// 2. O `<script type="application/ld+json">` invisível para o Google gerar os 'Rich Snippets'.

interface FAQ {
  question: string;
  answer: string;
}

interface Props {
  faqs?: FAQ[];
  title?: string;
}

const { faqs = [], title = "Perguntas Frequentes" } = Astro.props;

// Se não houver FAQs, não renderizamos nada
const hasFaqs = faqs && faqs.length > 0;

// Constrói o schema JSON-LD validado pro Google
const faqSchema = hasFaqs ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map((faq) => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
} : null;
---

{hasFaqs && (
<section class="max-w-4xl mx-auto my-16 px-4">
  <h2 class="text-3xl font-bold mb-8 text-center text-foreground">{title}</h2>
  
  <div class="space-y-4">
    {faqs.map((faq) => (
      <details class="group border border-border bg-card rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-shadow">
        <summary class="flex items-center justify-between p-6 cursor-pointer list-none font-semibold text-foreground group-open:bg-muted/30 transition-colors">
          <span class="text-lg">{faq.question}</span>
          <span class="transition-transform duration-300 group-open:rotate-180 flex-shrink-0 ml-4">
            <svg class="w-6 h-6 text-muted-foreground" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </span>
        </summary>
        <div class="p-6 pt-0 text-muted-foreground border-t border-border mt-2 prose prose-neutral max-w-none" set:html={faq.answer} />
      </details>
    ))}
  </div>

  <!-- Schema de SEO Injetado Automaticamente -->
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</section>
)}

<style>
  /* Esconde a setinha nativa do <details> no Chrome/Safari */
  details > summary::-webkit-details-marker {
    display: none;
  }
</style>
