---
// TableOfContents.astro — Índice com âncoras para o review
// Os headings vêm de entry.render() das Astro Content Collections.
// Produz Sitelinks no Google quando bem estruturado.

interface Heading {
  depth: number;   // 1 = H1, 2 = H2, 3 = H3
  slug: string;    // âncora gerada automaticamente pelo Astro
  text: string;    // texto do heading
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;

// Filtrar apenas H2 e H3 (H1 é o título da página)
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);

// Não renderizar se não houver headings suficientes
if (tocHeadings.length < 2) return;
---

<nav
  class="mx-auto max-w-4xl px-4 mb-8"
  aria-label="Índice do artigo"
  id="toc"
>
  <details class="group rounded-2xl border border-border bg-secondary/30 overflow-hidden" open>
    <summary class="flex items-center gap-3 px-5 py-4 cursor-pointer select-none hover:bg-secondary/60 transition-colors list-none">
      <span class="flex items-center justify-center w-7 h-7 rounded-lg bg-primary/10 flex-shrink-0">
        <svg class="w-4 h-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h10"/>
        </svg>
      </span>
      <span class="text-sm font-black text-foreground uppercase tracking-wide">O que você vai encontrar neste review</span>
      <svg
        class="w-4 h-4 text-muted-foreground ml-auto transition-transform group-open:rotate-180"
        fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"
      >
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
      </svg>
    </summary>

    <ol class="px-5 pb-5 pt-2 space-y-1 list-none">
      {tocHeadings.map((heading, i) => (
        <li class={heading.depth === 3 ? 'pl-5' : ''}>
          <a
            href={`#${heading.slug}`}
            class={`flex items-center gap-2 py-1.5 text-sm transition-colors hover:text-primary rounded-lg ${heading.depth === 2 ? 'font-semibold text-foreground' : 'text-muted-foreground'}`}
          >
            {heading.depth === 2 && (
              <span class="flex-shrink-0 w-5 h-5 rounded-md bg-primary/10 text-primary text-[10px] font-black flex items-center justify-center">
                {tocHeadings.filter((h) => h.depth === 2).indexOf(heading) + 1}
              </span>
            )}
            {heading.depth === 3 && (
              <span class="flex-shrink-0 w-1.5 h-1.5 rounded-full bg-muted-foreground/40 ml-1"></span>
            )}
            {heading.text}
          </a>
        </li>
      ))}
    </ol>
  </details>
</nav>

<style>
  /* Esconder o marcador padrão do <summary> em todos os browsers */
  summary::-webkit-details-marker { display: none; }
  summary::marker { display: none; }
</style>
