---
// AffiliateButton.astro
// Design Premium: Amazon (Black/Yellow) & Mercado Livre (Blue/Yellow)

export interface Props {
  type?: 'amazon' | 'mercadolivre';
  href?: string;
  url?: string;
  link?: string;
  label?: string;
  text?: string;
  class?: string;
}

const { 
  type = 'amazon', 
  href, 
  url, 
  link, 
  label, 
  text,
  class: className
} = Astro.props;

const finalHref = href || url || link || '#';
const finalLabel = label || text;
const isAmazon = type === 'amazon';
---

<div class="affiliate-btn-wrapper my-6 flex justify-center">
  <a
    href={finalHref}
    target="_blank"
    rel="nofollow sponsored noopener"
    class:list={['affiliate-btn', isAmazon ? 'amazon' : 'mercadolivre', className]}
  >
    <span class="btn-text">
      {finalLabel ? (
        <span class="text-white font-bold">{finalLabel}</span>
      ) : isAmazon ? (
        <>
          <span class="text-white">Ver preço na</span>
          <span class="text-amazon-yellow uppercase font-bold">Amazon</span>
        </>
      ) : (
        <>
          <span class="text-white">Ver preço no</span>
          <span class="text-ml-yellow font-bold">Mercado Livre</span>
        </>
      )}
    </span>
  </a>
</div>

<style>
  .affiliate-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: pointer;
    min-width: 260px;
    height: 52px;
    padding: 0 32px;
    font-family: system-ui, -apple-system, sans-serif;
    font-size: 16px;
    letter-spacing: 0.025em;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
    border-radius: 9999px; /* Cantos arredondados total */
  }

  /* Amazon - Preto padrão com detalhe amarelo */
  .amazon {
    background-color: #000000;
  }

  .amazon:hover {
    background-color: #232f3e;
    transform: translateY(-2px);
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.2);
  }

  /* Mercado Livre - Azul padrão com detalhe amarelo */
  .mercadolivre {
    background-color: #2D3277;
  }

  .mercadolivre:hover {
    background-color: #1e2255;
    transform: translateY(-2px);
    box-shadow: 0 10px 15px -3px rgba(45, 50, 119, 0.3);
  }

  .btn-text {
    display: flex;
    align-items: center;
    gap: 8px;
    white-space: nowrap;
  }

  .text-white {
    color: #FFFFFF;
  }

  .text-amazon-yellow {
    color: #FF9900; /* Amarelo Amazon */
  }

  .text-ml-yellow {
    color: #FFE600; /* Amarelo Mercado Livre */
  }

  @media (max-width: 640px) {
    .affiliate-btn {
      width: 100%;
      min-width: unset;
      font-size: 14px;
    }
  }
</style>