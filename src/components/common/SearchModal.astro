---
import { Icon } from 'astro-icon/components';
---

<div id="search-modal" class="fixed inset-0 z-50 hidden bg-slate-900/80 backdrop-blur-sm transition-opacity opacity-0">
  <div class="flex items-start justify-center min-h-screen px-4 pt-20 pb-4 text-center sm:p-0 sm:pt-24">
    <div
      class="relative w-full max-w-2xl overflow-hidden text-left bg-white dark:bg-slate-800 rounded-2xl shadow-2xl ring-1 ring-black/5 transform transition-all opacity-0 scale-95"
      id="search-container"
      role="dialog"
      aria-modal="true"
    >
      <!-- Cabeçalho (Input de Busca) -->
      <div class="relative flex items-center border-b border-slate-100 dark:border-slate-700/50 px-4 py-4 sm:px-6">
        <Icon name="tabler:search" class="w-6 h-6 text-slate-400 shrink-0" />
        <input
          type="text"
          id="search-input"
          class="w-full h-12 bg-transparent border-0 focus:ring-0 text-slate-900 dark:text-slate-100 placeholder-slate-400 text-lg outline-none ml-4"
          placeholder="Digite o que você procura... (Ex: Intelbras, Yale, Biometria)"
          autocomplete="off"
        />
        <button id="close-search-modal" class="ml-4 p-2 text-slate-400 hover:text-slate-500 rounded-lg shrink-0">
          <Icon name="tabler:x" class="w-6 h-6" />
        </button>
      </div>

      <!-- Resultados -->
      <div id="search-results" class="max-h-[60vh] overflow-y-auto px-2 py-2 sm:px-4 sm:py-4">
        <div id="search-placeholder" class="py-14 text-center text-sm text-slate-500 dark:text-slate-400">
          <Icon name="tabler:bulb" class="w-12 h-12 mx-auto text-slate-300 dark:text-slate-600 mb-4" />
          <p>Busque por guias, modelos de fechaduras ou tutoriais.</p>
        </div>
        <ul id="search-results-list" class="space-y-1"></ul>
      </div>
    </div>
  </div>
</div>

<script>
  let isSearchModalOpen = false;
  let searchData = [];
  let isDataLoaded = false;

  const searchModal = document.getElementById('search-modal');
  const searchContainer = document.getElementById('search-container');
  const searchInput = document.getElementById('search-input');
  const closeSearchBtn = document.getElementById('close-search-modal');
  const searchResultsList = document.getElementById('search-results-list');
  const searchPlaceholder = document.getElementById('search-placeholder');

  // Trigger para abrir o modal
  const openSearchButtons = document.querySelectorAll('[data-aw-search-toggle]');

  async function loadSearchData() {
    if (isDataLoaded) return;
    try {
      const res = await fetch('/api/search.json');
      searchData = await res.json();
      isDataLoaded = true;
    } catch (error) {
      console.error('Falha ao carregar os dados da busca:', error);
    }
  }

  function openSearch() {
    isSearchModalOpen = true;
    searchModal.classList.remove('hidden');
    // Animação de fade-in
    setTimeout(() => {
      searchModal.classList.remove('opacity-0');
      searchContainer.classList.remove('opacity-0', 'scale-95');
      searchContainer.classList.add('opacity-100', 'scale-100');
      searchInput.focus();
    }, 10);
    
    // Bloqueia rolagem da body
    document.body.style.overflow = 'hidden';
    
    // Carrega dados em background se ainda não recarregou
    loadSearchData();
  }

  function closeSearch() {
    isSearchModalOpen = false;
    searchModal.classList.add('opacity-0');
    searchContainer.classList.remove('opacity-100', 'scale-100');
    searchContainer.classList.add('opacity-0', 'scale-95');
    
    setTimeout(() => {
      searchModal.classList.add('hidden');
      searchResultsList.innerHTML = '';
      searchInput.value = '';
      searchPlaceholder.style.display = 'block';
      // Restaura rolagem
      document.body.style.overflow = '';
    }, 200);
  }

  function renderResults(query) {
    if (!query.trim()) {
      searchResultsList.innerHTML = '';
      searchPlaceholder.style.display = 'block';
      return;
    }
    
    searchPlaceholder.style.display = 'none';
    const lowerQuery = query.toLowerCase();
    
    const results = searchData.filter(item => 
      item.title.toLowerCase().includes(lowerQuery) || 
      item.description.toLowerCase().includes(lowerQuery)
    ).slice(0, 8); // Limita a 8 resultados

    if (results.length === 0) {
      searchResultsList.innerHTML = `
        <li class="py-8 text-center text-slate-500">
          Nenhum artigo encontrado para "<span class="font-semibold">${query}</span>".
        </li>
      `;
      return;
    }

    searchResultsList.innerHTML = results.map(item => {
      // Pequeno hack para gerar a URL correta no seu sistema basedo no slug/tipo
      // O AstroWind usa getPermalink, mas na API geramos o slug direto.
      return `
        <li>
          <a href="/${item.slug}" class="flex items-start px-4 py-3 rounded-xl hover:bg-slate-50 dark:hover:bg-slate-700/50 transition-colors group">
            <div class="flex-1 min-w-0">
              <h4 class="text-base font-semibold text-slate-900 dark:text-white truncate group-hover:text-primary transition-colors">
                ${item.title}
              </h4>
              <p class="text-sm text-slate-500 line-clamp-1 mt-0.5">
                ${item.description}
              </p>
            </div>
            <div class="hidden sm:flex shrink-0 ml-4 items-center">
              <span class="text-xs font-medium text-slate-400 bg-slate-100 dark:bg-slate-800 px-2 py-1 rounded-md uppercase tracking-wider">
                ${item.category || item.type}
              </span>
            </div>
          </a>
        </li>
      `;
    }).join('');
  }

  // Listeners
  openSearchButtons.forEach(btn => btn.addEventListener('click', openSearch));
  closeSearchBtn?.addEventListener('click', closeSearch);
  
  // Fecha clicando no fundo ESC
  searchModal?.addEventListener('click', (e) => {
    if (e.target === searchModal || e.target.parentElement === searchModal) {
      closeSearch();
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isSearchModalOpen) closeSearch();
    // Atalho CTRL+K ou CMD+K para abrir a busca
    if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
      e.preventDefault();
      openSearch();
    }
  });

  searchInput?.addEventListener('input', (e) => {
    renderResults(e.target.value);
  });
</script>
