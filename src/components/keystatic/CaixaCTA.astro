---
import AffiliateButton from '~/components/ui/AffiliateButton.astro';

interface Props {
  title: string;
  subtitle: string;
  amazonLink: string;
  meliLink: string;
}

const { title, subtitle, amazonLink, meliLink } = Astro.props;
---

<div class="my-10 rounded-2xl bg-gradient-to-br from-slate-800 to-slate-900 text-white p-8 text-center shadow-xl">
  <p class="text-xl font-bold mb-2">{title}</p>
  <p class="text-slate-300 mb-6">{subtitle}</p>
  <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
    <AffiliateButton
      type="amazon"
      href={amazonLink}
      text="Ver na Amazon"
      class="w-full sm:w-72"
    />
    <AffiliateButton
      type="mercadolivre"
      href={meliLink}
      text="Ver no Mercado Livre"
      class="w-full sm:w-72"
    />
  </div>
</div>
