---
import { marked } from 'marked';

interface Props {
  title: string;
  content: string;
  type: 'blue' | 'green' | 'yellow';
}

const { title, content, type = 'blue' } = Astro.props;

// Renderizar o conteúdo em markdown para html
const htmlContent = marked.parse(content);

let colorClass = 'bg-blue-50 dark:bg-blue-950/40 border-blue-400 text-slate-700 dark:text-slate-300';
if (type === 'green') {
  colorClass = 'bg-green-50 dark:bg-green-950/40 border-green-400 text-slate-700 dark:text-slate-300';
} else if (type === 'yellow') {
  colorClass = 'bg-yellow-50 dark:bg-yellow-950/40 border-yellow-400 text-slate-700 dark:text-slate-300';
}
---

<div class={`border-l-4 rounded-r-xl px-6 py-4 mb-8 ${colorClass}`}>
  <p class="font-semibold mb-1">{title}</p>
  <div class="prose prose-sm dark:prose-invert max-w-none" set:html={htmlContent} />
</div>
