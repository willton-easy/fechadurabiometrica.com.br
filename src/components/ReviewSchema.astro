---
interface Props {
  name: string;
  description: string;
  image: string;
  ratingValue?: string;
  bestRating?: string;
  authorName?: string;
  brand?: string;
  sku?: string;
}

const { 
  name, 
  description, 
  image, 
  ratingValue = "4.8", 
  bestRating = "5", 
  authorName = "Willton Alves",
  brand = "Intelbras",
  sku
} = Astro.props;

const schema = {
  "@context": "https://schema.org/",
  "@type": "Product",
  "name": name,
  "image": image,
  "description": description,
  "brand": {
    "@type": "Brand",
    "name": brand
  },
  "sku": sku || name.toLowerCase().replace(/\s+/g, '-'),
  "review": {
    "@type": "Review",
    "reviewRating": {
      "@type": "Rating",
      "ratingValue": ratingValue,
      "bestRating": bestRating
    },
    "author": {
      "@type": "Person",
      "name": authorName
    }
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": ratingValue,
    "reviewCount": "87"
  }
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
