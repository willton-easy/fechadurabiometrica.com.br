---
import ReviewSchema from './ReviewSchema.astro';

interface Product {
  rank: number;
  name: string;
  badge: string;
  badgeColor: "primary" | "accent" | "cta";
  image: string;
  specs: string[];
  verdict: string;
  pros: string[];
  cons: string[];
  amazonUrl: string;
  mlUrl: string;
  reviewUrl: string;
  brand?: string;
}

interface Props {
  product: Product;
  showSchema?: boolean;
}

const { product, showSchema = true } = Astro.props;

const badgeClass = {
  primary: "bg-primary/10 text-primary border-primary/20",
  accent: "bg-accent/10 text-accent border-accent/20",
  cta: "bg-cta/10 text-cta border-cta/20",
};
---

<div class="relative flex flex-col gap-6 rounded-3xl border border-border bg-card p-6 shadow-sm transition-all hover:border-primary/30 hover:shadow-md lg:flex-row lg:gap-8 lg:p-8" id={`produto-${product.rank}`} itemscope itemtype="https://schema.org/Product">
  {showSchema && <ReviewSchema 
    name={product.name} 
    description={product.verdict} 
    image={product.image} 
    brand={product.brand}
  />}
  
  <div class="flex flex-col items-center gap-4 lg:w-64 lg:flex-shrink-0">
    <div class="flex items-center gap-3 self-start">
      <div class={`flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-xl text-lg font-extrabold ${product.rank <= 3 ? 'bg-primary text-primary-foreground shadow-md shadow-primary/25' : 'bg-secondary text-muted-foreground'}`}>
        {product.rank}
      </div>
      <span class={`rounded-full border px-3 py-1 text-xs font-semibold ${badgeClass[product.badgeColor]}`}>
        {product.badge}
      </span>
    </div>
    
    <a 
      href={product.amazonUrl} 
      target="_blank" 
      rel="nofollow sponsored"
      class="relative flex h-56 w-full items-center justify-center overflow-hidden rounded-xl bg-white p-4 lg:h-52 lg:w-60 transition-all hover:ring-2 hover:ring-primary/20"
      aria-label={`Ver ${product.name} na Amazon`}
    >
       <img 
        src={product.image} 
        alt={product.name}
        class="h-full w-full object-contain transition-all duration-300 hover:scale-110 cursor-pointer"
        loading={product.rank <= 3 ? "eager" : "lazy"}
        itemprop="image"
      />
    </a>
  </div>

  <div class="flex flex-1 flex-col gap-4">
    <h3 class="text-xl font-bold text-foreground" itemprop="name">
      <a href={product.reviewUrl} class="transition-colors hover:text-primary">
        {product.name}
      </a>
    </h3>

    <div class="flex flex-wrap gap-2">
      {product.specs.map((spec) => (
        <span class="rounded-lg bg-secondary px-3 py-1.5 text-xs font-medium text-secondary-foreground">
          {spec}
        </span>
      ))}
    </div>

    <p class="text-sm leading-relaxed text-muted-foreground" itemprop="description">
      {product.verdict}
    </p>

    <div class="grid gap-4 sm:grid-cols-2">
      <div>
        <p class="mb-2 text-xs font-semibold uppercase tracking-wider text-primary">O que gostamos</p>
        <ul class="flex flex-col gap-1.5 line-clamp-4 overflow-hidden h-28">
          {product.pros.map((pro) => (
            <li class="flex items-start gap-2 text-[13px] text-foreground">
              <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              {pro}
            </li>
          ))}
        </ul>
      </div>
      <div>
        <p class="mb-2 text-xs font-semibold uppercase tracking-wider text-destructive">Pontos de atenção</p>
        <ul class="flex flex-col gap-1.5 line-clamp-4 overflow-hidden h-28">
          {product.cons.map((con) => (
            <li class="flex items-start gap-2 text-[13px] text-foreground">
              <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-destructive" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
              {con}
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mt-4 flex flex-col gap-3 sm:flex-row">
      <a
        href={product.mlUrl}
        target="_blank"
        rel="nofollow sponsored"
        class="flex flex-1 items-center justify-center gap-2 rounded-xl bg-[#FFE600] py-3 text-sm font-black text-[#2d3277] shadow-sm transition-transform hover:scale-105"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 48 48" class="text-white"><ellipse cx="24" cy="24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" rx="19.5" ry="12.978"/><path fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="M9.704 15.53a20.8 20.8 0 0 0 6.386 1.866a23 23 0 0 0 4.546-.773"/><path fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="M38.882 15.614a8.6 8.6 0 0 1-5.165 1.485c-3.335 0-6.225-2.199-9.215-2.199c-2.668 0-7.189 4.373-7.189 5.164s1.31 1.26 2.372.74c.621-.303 3.31-2.914 5.484-2.914s9.219 7.136 9.857 7.806c.989 1.038-.926 3.274-2.149 2.05s-3.41-3.162-3.41-3.162"/><path fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="M43.4 22.683a24 24 0 0 0-8.547 2.692m-2.273 2.081c.989 1.037-.926 3.273-2.149 2.05s-2.581-2.513-2.581-2.513"/><path fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="M30.135 29.215c.988 1.037-.927 3.273-2.15 2.05s-2.025-1.962-2.025-1.962"/><path fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="M24.202 31.316a2.31 2.31 0 0 0 3.648-.186"/><path fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2.5" stroke-linejoin="round" d="M24.202 31.316c.53-.697.49-3.182-2.244-2.688c.642-1.219.066-3.146-2.388-2.01a1.69 1.69 0 0 0-3.146-.658a1.455 1.455 0 0 0-2.8-.28c-.544 1.104.296 3.096 2.092 1.976c-.182 1.944.84 2.537 2.684 1.78c.099 1.91 1.367 1.745 2.273 1.3a1.938 1.938 0 0 0 3.529.58"/><path fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="M4.67 22.279a18.3 18.3 0 0 1 9.064 3.214"/></svg>
        MERCADO LIVRE
      </a>
      <a
        href={product.amazonUrl}
        target="_blank"
        rel="nofollow sponsored"
        class="flex flex-1 items-center justify-center gap-2 rounded-xl bg-[#FF9900] py-3 text-sm font-black text-black transition-colors hover:bg-[#E68A00]"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" class="text-black"><path fill="currentColor" d="M21.997 18.23c0 .727-.405 2.127-1.315 2.896c-.182.14-.364.061-.284-.143c.265-.648.871-2.147.587-2.492c-.201-.262-1.031-.242-1.739-.182c-.323.041-.607.06-.827.105c-.204.016-.245-.163-.041-.303a3.1 3.1 0 0 1 .87-.428c1.15-.344 2.479-.137 2.67.083c.036.042.079.16.079.463m-1.922 1.294a7 7 0 0 1-.829.55c-2.122 1.275-4.871 1.943-7.258 1.943c-3.843 0-7.28-1.417-9.888-3.788c-.224-.182-.039-.446.223-.303c2.81 1.64 6.288 2.632 9.888 2.632c2.266 0 4.708-.424 7.035-1.336c.163-.061.345-.144.504-.202c.367-.165.69.242.325.504m-6.17-11.03c0-1.041.042-1.654-.303-2.18c-.306-.433-.833-.693-1.569-.652c-.798.044-1.655.567-1.873 1.526c-.043.22-.171.436-.437.483l-2.435-.31c-.174-.04-.439-.173-.352-.521C7.459 4.088 9.81 3.129 12.034 3h.522c1.22 0 2.788.349 3.791 1.264c1.217 1.136 1.087 2.662 1.087 4.32v3.927c0 1.178.478 1.7.958 2.314c.13.219.175.477-.044.655a78 78 0 0 1-1.917 1.654c-.175.133-.489.147-.61.045c-.77-.645-.958-1.003-1.435-1.658c-.83.871-1.527 1.352-2.356 1.613a7 7 0 0 1-1.784.216c-2.09 0-3.745-1.303-3.745-3.88c0-2.049 1.09-3.442 2.7-4.101c1.61-.66 3.95-.87 4.704-.874m-.477 5.192c.52-.872.477-1.586.477-3.185c-.652 0-1.306.045-1.871.178c-1.045.303-1.875.96-1.875 2.355c0 1.09.568 1.832 1.526 1.832q.198 0 .348-.045c.67-.186 1.088-.522 1.395-1.135"/></svg>
        VER NA AMAZON
      </a>
    </div>
  </div>
</div>
