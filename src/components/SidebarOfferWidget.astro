---
import { products } from '../lib/products';

interface Props {
  productIds?: number[];
  title?: string;
}

// Por padrão, pega a Yale (1) e a Intelbras (2) se não passar IDs
const { productIds = [1, 2], title = "⭐ Ofertas Recomendadas" } = Astro.props;

const promotedProducts = products.filter(p => productIds.includes(p.id));

if (promotedProducts.length === 0) return null;

// Helper para gerar as estrelinhas baseadas no rating
function getStarClasses(rating: number, index: number) {
  if (rating >= index) return "text-[#FF9900]"; // Estrela cheia (cor da Amazon)
  if (rating >= index - 0.5) return "text-[#FF9900]"; // Meia estrela
  return "text-gray-300 dark:text-gray-700"; // Estrela vazia
}
---

<div class="sidebar-offer-widget sticky top-24 space-y-8 pb-10">
  <div class="px-2 mb-4">
    <h3 class="text-xl font-black text-foreground uppercase tracking-tight flex items-center gap-2 border-b-2 border-primary/20 pb-2">
      {title}
    </h3>
  </div>

  <div class="space-y-6">
    {promotedProducts.map((product) => {
      // Monta as fotos que serão usadas (a primeira é sempre a default)
      const fotos = product.gallery && product.gallery.length > 0 
        ? [product.image, ...product.gallery] 
        : [product.image];

      return (
        <div class="product-offer-card bg-card border border-border rounded-2xl p-5 shadow-sm hover:shadow-lg transition-shadow">
          
          <!-- Galeria de Imagens -->
          <div class="gallery-container mb-4" data-product-id={product.id}>
            <!-- Imagem Principal -->
            <div class="main-image-wrapper bg-white border border-border rounded-xl aspect-square flex items-center justify-center p-4 mb-3 relative overflow-hidden group">
              {product.badge && (
                 <span class="absolute top-2 left-2 bg-emerald-500 text-black text-[10px] uppercase font-black px-2 py-0.5 rounded shadow-sm z-10">
                   {product.badge.replaceAll('*', '')}
                 </span>
              )}
              <img 
                id={`main-img-${product.id}`}
                src={fotos[0]} 
                alt={product.name} 
                loading="lazy"
                class="w-full h-full object-contain mix-blend-multiply transition-transform duration-300 group-hover:scale-105"
              />
            </div>

            <!-- Miniaturas (Thumbnails) -->
            {fotos.length > 1 && (
              <div class="thumbnails-row flex gap-2 overflow-x-auto pb-1 scrollbar-hide">
                {fotos.map((foto, index) => (
                  <button 
                    type="button"
                    class={`thumbnail-btn w-12 h-12 flex-shrink-0 bg-white border rounded-lg p-1 transition-all ${index === 0 ? 'border-primary ring-1 ring-primary' : 'border-border hover:border-primary/50'}`}
                    data-target={`main-img-${product.id}`}
                    data-src={foto}
                    aria-label={`Ver foto ${index + 1} de ${product.name}`}
                  >
                    <img src={foto} alt="" class="w-full h-full object-contain mix-blend-multiply opacity-90 hover:opacity-100" />
                  </button>
                ))}
              </div>
            )}
          </div>

          <!-- Dados do Produto -->
          <div class="product-info flex flex-col">
            <h4 class="font-bold text-foreground leading-tight mb-2 hover:text-primary transition-colors line-clamp-2">
              <a href={product.reviewUrl}>{product.name}</a>
            </h4>
            
            <!-- Estrelas e Reviews -->
            <div class="flex items-center gap-1.5 mb-4">
              <div class="flex">
                {[1, 2, 3, 4, 5].map((index) => (
                  <svg 
                    class={`w-4 h-4 ${getStarClasses(product.rating || 5, index)}`} 
                    viewBox="0 0 20 20" 
                    fill="currentColor"
                  >
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
              {product.reviewsCount && (
                <span class="text-xs text-blue-500 hover:underline cursor-pointer">({product.reviewsCount})</span>
              )}
            </div>

            <!-- Preço Simulado / Chamada à Ação -->
            <div class="mb-4">
               <p class="text-[11px] text-muted-foreground uppercase font-black flex items-center gap-1 mb-1">
                 <span class="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse"></span>
                 Em Estoque
               </p>
               <p class="text-xs text-muted-foreground italic">Verificar prêço atualizado no site</p>
            </div>

            <!-- Botões de Afiliado (Sidebar Style) -->
            <div class="flex flex-col gap-2 mt-auto">
              <a 
                href={product.amazonUrl} 
                target="_blank" 
                rel="nofollow sponsored" 
                class="w-full bg-[#FF9900] hover:bg-[#E68A00] text-black font-black text-sm py-2.5 px-3 rounded-xl flex items-center justify-center gap-2 transition-transform hover:scale-[1.03] shadow-sm"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"><path fill="currentColor" d="M21.997 18.23c0 .727-.405 2.127-1.315 2.896c-.182.14-.364.061-.284-.143c.265-.648.871-2.147.587-2.492c-.201-.262-1.031-.242-1.739-.182c-.323.041-.607.06-.827.105c-.204.016-.245-.163-.041-.303a3.1 3.1 0 0 1 .87-.428c1.15-.344 2.479-.137 2.67.083c.036.042.079.16.079.463m-1.922 1.294a7 7 0 0 1-.829.55c-2.122 1.275-4.871 1.943-7.258 1.943c-3.843 0-7.28-1.417-9.888-3.788c-.224-.182-.039-.446.223-.303c2.81 1.64 6.288 2.632 9.888 2.632c2.266 0 4.708-.424 7.035-1.336c.163-.061.345-.144.504-.202c.367-.165.69.242.325.504m-6.17-11.03c0-1.041.042-1.654-.303-2.18c-.306-.433-.833-.693-1.569-.652c-.798.044-1.655.567-1.873 1.526c-.043.22-.171.436-.437.483l-2.435-.31c-.174-.04-.439-.173-.352-.521C7.459 4.088 9.81 3.129 12.034 3h.522c1.22 0 2.788.349 3.791 1.264c1.217 1.136 1.087 2.662 1.087 4.32v3.927c0 1.178.478 1.7.958 2.314c.13.219.175.477-.044.655a78 78 0 0 1-1.917 1.654c-.175.133-.489.147-.61.045c-.77-.645-.958-1.003-1.435-1.658c-.83.871-1.527 1.352-2.356 1.613a7 7 0 0 1-1.784.216c-2.09 0-3.745-1.303-3.745-3.88c0-2.049 1.09-3.442 2.7-4.101c1.61-.66 3.95-.87 4.704-.874m-.477 5.192c.52-.872.477-1.586.477-3.185c-.652 0-1.306.045-1.871.178c-1.045.303-1.875.96-1.875 2.355c0 1.09.568 1.832 1.526 1.832q.198 0 .348-.045c.67-.186 1.088-.522 1.395-1.135"/></svg>
                VER NA AMAZON
              </a>
              <a 
                href={product.mlUrl} 
                target="_blank" 
                rel="nofollow sponsored" 
                class="w-full bg-[#FFE600] text-[#2d3277] hover:bg-[#F0D800] font-black text-sm py-2.5 px-3 rounded-xl flex items-center justify-center gap-2 transition-transform hover:scale-[1.03] shadow-sm"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 48 48"><ellipse cx="24" cy="24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" rx="19.5" ry="12.978"/><path fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="M9.704 15.53a20.8 20.8 0 0 0 6.386 1.866a23 23 0 0 0 4.546-.773"/><path fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="M38.882 15.614a8.6 8.6 0 0 1-5.165 1.485c-3.335 0-6.225-2.199-9.215-2.199c-2.668 0-7.189 4.373-7.189 5.164s1.31 1.26 2.372.74c.621-.303 3.31-2.914 5.484-2.914s9.219 7.136 9.857 7.806c.989 1.038-.926 3.274-2.149 2.05s-3.41-3.162-3.41-3.162"/><path fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="M43.4 22.683a24 24 0 0 0-8.547 2.692m-2.273 2.081c.989 1.037-.926 3.273-2.149 2.05s-2.581-2.513-2.581-2.513"/><path fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="M30.135 29.215c.988 1.037-.927 3.273-2.15 2.05s-2.025-1.962-2.025-1.962"/><path fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="M24.202 31.316a2.31 2.31 0 0 0 3.648-.186"/><path fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2.5" stroke-linejoin="round" d="M24.202 31.316c.53-.697.49-3.182-2.244-2.688c.642-1.219.066-3.146-2.388-2.01a1.69 1.69 0 0 0-3.146-.658a1.455 1.455 0 0 0-2.8-.28c-.544 1.104.296 3.096 2.092 1.976c-.182 1.944.84 2.537 2.684 1.78c.099 1.91 1.367 1.745 2.273 1.3a1.938 1.938 0 0 0 3.529.58"/><path fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="M4.67 22.279a18.3 18.3 0 0 1 9.064 3.214"/></svg>
                VER NO MERCADO LIVRE
              </a>
            </div>
            
            <a href={product.reviewUrl} class="text-center text-xs text-blue-500 font-bold mt-3 hover:underline">Ler nossa Análise Completa</a>
          </div>
        </div>
      );
    })}
  </div>
</div>

<style>
  /* Ocultar barra de rolagem das miniaturas, mas manter funcionamento */
  .scrollbar-hide::-webkit-scrollbar {
      display: none;
  }
  .scrollbar-hide {
      -ms-overflow-style: none;
      scrollbar-width: none;
  }
</style>

<script>
  // Script para a interatividade da Galeria (Thumbnail clica -> muda a main image)
  document.addEventListener('DOMContentLoaded', () => {
    const thumbBtns = document.querySelectorAll('.thumbnail-btn');
    
    thumbBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        const targetId = btn.getAttribute('data-target');
        const newSrc = btn.getAttribute('data-src');
        
        if (targetId && newSrc) {
          const mainImgElem = document.getElementById(targetId) as HTMLImageElement;
          if (mainImgElem) {
            mainImgElem.src = newSrc;
            
            // Atualizar o anel (highlight) verde na thumbnail selecionada
            const parentRow = btn.closest('.thumbnails-row');
            if (parentRow) {
              parentRow.querySelectorAll('.thumbnail-btn').forEach(b => {
                b.classList.remove('border-primary', 'ring-1', 'ring-primary');
                b.classList.add('border-border');
              });
            }
            btn.classList.remove('border-border');
            btn.classList.add('border-primary', 'ring-1', 'ring-primary');
          }
        }
      });
    });
  });
</script>
