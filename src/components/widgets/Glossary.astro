---
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import Headline from '~/components/ui/Headline.astro';
import { Icon } from 'astro-icon/components';
import { glossaryItems } from '~/data/glossary';

const categories = [...new Set(glossaryItems.map(item => item.category))];

const {
  title = "Enciclopédia Técnica",
  subtitle = "O dicionário definitivo das fechaduras digitais de 2026",
  tagline = "Glossário Completo",
  id = "glossario",
  isDark = false,
  classes = {},
  bg = await Astro.slots.render('bg'),
} = Astro.props;
---

<WidgetWrapper id={id} isDark={isDark} containerClass={`max-w-7xl mx-auto ${classes?.container ?? ''}`} bg={bg}>
  <Headline title={title} subtitle={subtitle} tagline={tagline} />
  
  <div class="relative">
    <div id="glossary-container" class="max-h-[500px] overflow-hidden transition-all duration-700 ease-in-out relative">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 px-4">
        {categories.map((cat) => (
          <div class="space-y-4">
            <h3 class="text-lg font-bold text-primary flex items-center gap-2 border-b border-slate-200 dark:border-slate-800 pb-2 mb-3">
              <Icon name="tabler:folder" class="w-4 h-4" />
              {cat}
            </h3>
            
            <ul class="space-y-2">
              {glossaryItems
                .filter(item => item.category === cat)
                .map((item) => (
                  <li class="group">
                    <details class="glossary-item transition-all duration-200">
                      <summary class="flex items-center gap-2 cursor-pointer list-none text-sm font-medium text-slate-700 dark:text-slate-300 hover:text-primary">
                        <span class="w-1.5 h-1.5 rounded-full bg-primary/40 group-hover:bg-primary transition-colors"></span>
                        {item.title}
                      </summary>
                      <div class="mt-2 pl-4 text-xs text-muted leading-relaxed border-l-2 border-primary/20 py-1">
                        {item.description}
                      </div>
                    </details>
                  </li>
                ))
              }
            </ul>
          </div>
        ))}
      </div>

      <!-- Gradient Overlay to hide content -->
      <div id="glossary-overlay" class="absolute bottom-0 left-0 w-full h-40 bg-gradient-to-t from-white dark:from-slate-950 to-transparent z-10 pointer-events-none"></div>
    </div>

    <!-- Toggle Button (Gaveta) -->
    <div class="flex justify-center mt-8 relative z-20">
      <button
        id="toggle-glossary"
        class="group flex items-center gap-2 px-8 py-3 bg-primary text-white rounded-full font-bold shadow-lg hover:shadow-primary/30 hover:scale-105 transition-all duration-300"
      >
        <span id="toggle-text">Explorar Glossário Completo</span>
        <Icon name="tabler:chevron-down" id="toggle-icon" class="w-5 h-5 transition-transform duration-500" />
      </button>
    </div>
  </div>
</WidgetWrapper>

<script is:inline>
  const container = document.getElementById('glossary-container');
  const overlay = document.getElementById('glossary-overlay');
  const button = document.getElementById('toggle-glossary');
  const text = document.getElementById('toggle-text');
  const icon = document.getElementById('toggle-icon');

  if (button && container) {
    button.addEventListener('click', () => {
      const isExpanded = container.style.maxHeight === 'none' || container.style.maxHeight === '5000px';
      
      if (isExpanded) {
        container.style.maxHeight = '500px';
        overlay.style.opacity = '1';
        text.innerText = 'Explorar Glossário Completo';
        icon.style.transform = 'rotate(0deg)';
        container.scrollIntoView({ behavior: 'smooth' });
      } else {
        container.style.maxHeight = '5000px';
        overlay.style.opacity = '0';
        text.innerText = 'Recolher Glossário';
        icon.style.transform = 'rotate(180deg)';
      }
    });
  }
</script>

<style>
  details > summary::-webkit-details-marker {
    display: none;
  }
  
  .glossary-item[open] {
    @apply mb-4;
  }
</style>
