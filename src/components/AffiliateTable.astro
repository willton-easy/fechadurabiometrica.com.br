---
// AffiliateTable.astro — Tabela de afiliados estilo AffiliateX
// Suporta: imagens com zoom lightbox, logos Amazon + ML, badges, avaliações
import { getEntry } from 'astro:content';
import AffiliateButton from '~/components/ui/AffiliateButton.astro';

export interface ProductImage {
  src: string; // URL base, ex: https://m.media-amazon.com/images/I/51DTd911ugL
  alt?: string;
}

export interface Product {
  position?: number;
  title: string;
  image?: string;
  badge?: string;
  rating?: number;
  reviewCount?: number;
  amazonLink?: string;
  mercadoLivreLink?: string;
  extraImages?: string[];
  features?: string[];
  price?: string;
  description?: string;
}

export interface Props {
  products: (Product | string)[];
  title?: string;
}

const { products: rawProducts = [], title } = Astro.props;

// Resolvendo produtos que são apenas strings (slugs de reviews)
const resolvedProducts = await Promise.all(
  rawProducts.map(async (item, index) => {
    if (typeof item === 'string') {
      const entry = await getEntry('reviews', item);
      if (entry) {
        return {
          position: index + 1,
          title: entry.data.title,
          image: entry.data.image || '',
          rating: entry.data.ratingValue,
          reviewCount: entry.data.reviewCount,
          amazonLink: entry.data.affiliateLink,
          badge: entry.data.highlight, 
          extraImages: [],
        } as Product;
      }
      return null;
    }
    const productItem = item as Product;
    return { ...productItem, position: productItem.position || index + 1 } as Product;
  })
);

const products = resolvedProducts.filter((p): p is Product => p !== null);

// Helper: gera URL em diferentes tamanhos a partir da URL base Amazon
function amazonImgSize(url: string, size: string) {
  if (!url || !url.includes('amazon.com')) return url || '';
  
  // Se a URL já contiver um modificador comum (ex: ._AC_SL1500_.), tenta substituir
  // Amazon modifiers seguem o padrão ._XXXX_.
  const pattern = /\._[a-zA-Z0-9]+_\./;
  if (pattern.test(url)) {
    return url.replace(pattern, `._AC_SL${size}_.`);
  }
  
  // Se não tiver modificador, insere antes da extensão
  return url.replace(/(\.[a-z]+)$/, `._AC_SL${size}_$1`);
}
---

{title && <h2 class="text-2xl font-bold mb-6 text-slate-800 dark:text-slate-100">{title}</h2>}

<!-- Lightbox overlay -->
<div
  id="img-lightbox"
  class="fixed inset-0 z-50 hidden items-center justify-center bg-black/80 backdrop-blur-sm p-4"
  role="dialog"
  aria-modal="true"
  aria-label="Imagem ampliada do produto"
>
  <button
    id="lightbox-close"
    class="absolute top-4 right-4 text-white bg-white/20 hover:bg-white/40 rounded-full w-10 h-10 flex items-center justify-center text-2xl transition-all z-10"
    aria-label="Fechar">×</button
  >
  <img
    id="lightbox-img"
    src=""
    alt="Produto ampliado"
    class="max-w-full max-h-[90vh] object-contain rounded-xl shadow-2xl"
  />
</div>

<div
  class="affiliate-table not-prose my-8 rounded-xl overflow-hidden border border-slate-200 dark:border-slate-700 shadow-lg"
>
  {
    products.map((product) => {
      const hdUrl = amazonImgSize(product.image, '1500');
      const medUrl = amazonImgSize(product.image, '600');

      return (
        <div class="product-row flex flex-col md:flex-row items-center gap-4 p-4 border-b border-slate-100 dark:border-slate-800 hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors">
          {/* Posição */}
          <div class="flex-shrink-0 w-10 h-10 rounded-full bg-primary text-white text-lg font-bold flex items-center justify-center shadow">
            {product.position}
          </div>

          {/* Imagem com zoom ao clicar */}
          <div class="flex-shrink-0 flex flex-col items-center gap-1.5">
            <button
              class="img-zoom-btn group relative cursor-zoom-in"
              data-hd={product.image ? hdUrl : ''}
              data-alt={product.title}
              disabled={!product.image}
              aria-label={product.image ? `Ampliar imagem de ${product.title}` : `Imagem de ${product.title}`}
            >
              {product.image ? (
                <img
                  src={medUrl}
                  alt={product.title}
                  class="w-32 h-32 md:w-36 md:h-36 object-contain rounded-lg border border-slate-100 dark:border-slate-700 group-hover:scale-105 transition-transform duration-200"
                  loading="lazy"
                />
              ) : (
                <div class="w-32 h-32 md:w-36 md:h-36 flex items-center justify-center bg-slate-100 dark:bg-slate-800 rounded-lg border border-slate-200 dark:border-slate-700">
                   <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                   </svg>
                </div>
              )}
              {product.image && (
                <span class="absolute inset-0 flex items-end justify-center pb-1 opacity-0 group-hover:opacity-100 transition-opacity">
                  <span class="bg-black/60 text-white text-[10px] rounded px-1.5 py-0.5">🔍 Ampliar</span>
                </span>
              )}
            </button>

            {/* Miniaturas extras */}
            {product.extraImages && product.extraImages.length > 0 && (
              <div class="flex gap-1 mt-1">
                {product.extraImages.slice(0, 3).map((extraImg) => (
                  <button
                    class="img-zoom-btn w-7 h-7 overflow-hidden rounded border border-slate-200 dark:border-slate-600 hover:border-primary transition-colors cursor-zoom-in"
                    data-hd={amazonImgSize(extraImg, '1500')}
                    data-alt={product.title}
                    aria-label="Ver foto alternativa"
                  >
                    <img
                      src={amazonImgSize(extraImg, '300')}
                      alt=""
                      class="w-full h-full object-contain"
                      loading="lazy"
                    />
                  </button>
                ))}
              </div>
            )}
          </div>

          {/* Info do produto */}
          <div class="flex-grow min-w-0">
            {product.badge && (
              <span class="inline-block text-xs bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200 px-2 py-0.5 rounded-full font-semibold border border-yellow-300 dark:border-yellow-700 mb-1.5">
                {product.badge}
              </span>
            )}
            <h3 class="font-semibold text-slate-800 dark:text-slate-100 text-sm md:text-base leading-snug mb-1.5">
              {product.title}
            </h3>

            {product.features && (
              <div class="flex flex-wrap gap-1 mb-2">
                {product.features.map(f => (
                  <span class="text-[10px] bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400 px-1.5 py-0.5 rounded border border-slate-200 dark:border-slate-700">
                    {f}
                  </span>
                ))}
              </div>
            )}

            {product.price && (
              <p class="text-primary font-bold text-sm mb-1.5">{product.price}</p>
            )}

            {product.rating && (
              <div class="flex items-center gap-1 text-sm">
                <span class="text-yellow-500 tracking-tighter">
                  {'★'.repeat(Math.round(product.rating))}
                  {'☆'.repeat(5 - Math.round(product.rating))}
                </span>
                <span class="text-slate-500 dark:text-slate-400 text-xs">
                  {product.rating} ({product.reviewCount?.toLocaleString('pt-BR')} avaliações)
                </span>
              </div>
            )}
          </div>

          {/* Botões de CTA */}
          <div class="flex-shrink-0 flex flex-col gap-2 w-full md:w-auto">
            <AffiliateButton type="amazon" href={product.amazonLink} class="w-full md:w-60" />
            {product.mercadoLivreLink && (
              <AffiliateButton type="mercadolivre" href={product.mercadoLivreLink} class="w-full md:w-60" />
            )}
          </div>
        </div>
      );
    })
  }
</div>

{/* Script lightbox */}
<script>
  function initLightbox() {
    const lightbox = document.getElementById('img-lightbox')!;
    const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
    const closeBtn = document.getElementById('lightbox-close')!;

    function openLightbox(src: string, alt: string) {
      lightboxImg.src = src;
      lightboxImg.alt = alt;
      lightbox.classList.remove('hidden');
      lightbox.classList.add('flex');
      document.body.style.overflow = 'hidden';
    }

    function closeLightbox() {
      lightbox.classList.add('hidden');
      lightbox.classList.remove('flex');
      lightboxImg.src = '';
      document.body.style.overflow = '';
    }

    document.querySelectorAll<HTMLButtonElement>('.img-zoom-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const hd = btn.dataset.hd || '';
        const alt = btn.dataset.alt || 'Produto';
        openLightbox(hd, alt);
      });
    });

    closeBtn.addEventListener('click', closeLightbox);
    lightbox.addEventListener('click', (e) => {
      if (e.target === lightbox) closeLightbox();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeLightbox();
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initLightbox);
  } else {
    initLightbox();
  }
</script>

<style>
  .affiliate-table .product-row:last-child {
    border-bottom: none;
  }
</style>
