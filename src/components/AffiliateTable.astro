---
export interface Product {
  position: number;
  title: string;
  image: string;
  badge?: string;
  rating?: number;
  reviewCount?: number;
  amazonLink: string;
  mercadoLivreLink?: string;
}

export interface Props {
  products: Product[];
  title?: string;
}

const { products, title } = Astro.props;
---

{title && <h2 class="text-2xl font-bold mb-6 text-slate-800 dark:text-slate-100">{title}</h2>}

<div
  class="affiliate-table not-prose my-8 rounded-xl overflow-hidden border border-slate-200 dark:border-slate-700 shadow-lg"
>
  {
    products.map((product) => (
      <div class="product-row flex flex-col md:flex-row items-center gap-4 p-4 border-b border-slate-100 dark:border-slate-800 hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors">
        {/* Position badge */}
        <div class="flex-shrink-0 w-10 h-10 rounded-full bg-primary text-white text-lg font-bold flex items-center justify-center">
          {product.position}
        </div>

        {/* Product image */}
        <div class="flex-shrink-0 w-24 h-24 flex items-center justify-center">
          <img src={product.image} alt={product.title} class="max-w-full max-h-full object-contain" loading="lazy" />
        </div>

        {/* Product info */}
        <div class="flex-grow min-w-0">
          <div class="flex flex-wrap items-center gap-2 mb-1">
            {product.badge && (
              <span class="text-xs bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200 px-2 py-0.5 rounded-full font-semibold border border-yellow-300 dark:border-yellow-700">
                {product.badge}
              </span>
            )}
          </div>
          <h3 class="font-semibold text-slate-800 dark:text-slate-100 text-sm md:text-base leading-snug mb-1">
            {product.title}
          </h3>
          {product.rating && (
            <div class="flex items-center gap-1 text-sm text-yellow-500">
              {'★'.repeat(Math.round(product.rating))}
              {'☆'.repeat(5 - Math.round(product.rating))}
              {product.reviewCount && (
                <span class="text-slate-500 dark:text-slate-400 text-xs">({product.reviewCount} avaliações)</span>
              )}
            </div>
          )}
        </div>

        {/* CTA Buttons */}
        <div class="flex-shrink-0 flex flex-col gap-2 w-full md:w-auto">
          <a
            href={product.amazonLink}
            target="_blank"
            rel="nofollow sponsored noopener"
            class="flex items-center justify-center gap-2 bg-[#FF9900] hover:bg-[#e68a00] text-[#111] font-bold py-2.5 px-4 rounded-lg transition-all text-sm whitespace-nowrap shadow hover:shadow-md"
          >
            <svg
              width="18"
              height="18"
              viewBox="0 0 603.4 182.8"
              xmlns="http://www.w3.org/2000/svg"
              fill="#111"
              aria-label="Amazon"
            >
              <path d="M375.1 141.3c-35 25.8-85.8 39.6-129.5 39.6-61.3 0-116.4-22.7-158.2-60.4-3.3-3 -.3-7 3.6-4.7 45.1 26.2 100.8 41.9 158.3 41.9 38.8 0 81.5-8 120.8-24.7 5.9-2.5 10.9 3.9 5 8.3zm14.2-16.2c-4.5-5.7-29.6-2.7-40.9-1.4-3.4.4-4-2.6-.9-4.7 20-14.1 52.8-10 56.6-5.3 3.8 4.8-1 37.7-19.8 53.4-2.9 2.4-5.6 1.1-4.3-2.1 4.2-10.5 13.7-34.2 9.3-39.9z" />
              <path d="M138.8 31.3V18c0-2 1.5-3.3 3.3-3.3h58.7c1.9 0 3.4 1.4 3.4 3.3v11.5c0 1.9-1.6 4.3-4.4 8.2l-30.5 43.5c11.3-.3 23.3 1.4 33.6 7.2 2.3 1.3 2.9 3.2 3.1 5.1v14c0 1.9-2.1 4.1-4.3 3-18-9.4-41.9-10.4-61.8.1-2 1.1-4.2-1.1-4.2-3v-13.3c0-2.1 0-5.7 2.2-8.9l35.3-50.6H142c-1.9 0-3.2-1.3-3.2-3.5zm-105 0V18c0-2 1.5-3.3 3.3-3.3h58.7c1.9 0 3.4 1.4 3.4 3.3v11.5c0 1.9-1.6 4.3-4.4 8.2l-30.5 43.5c11.3-.3 23.3 1.4 33.6 7.2 2.3 1.3 2.9 3.2 3.1 5.1v14c0 1.9-2.1 4.1-4.3 3C78.7 101.1 54.8 100.1 34.9 110.6c-2 1.1-4.2-1.1-4.2-3V94.3c0-2.1 0-5.7 2.2-8.9l35.3-50.6H37c-1.9 0-3.2-1.3-3.2-3.5zm395.5 67.2h-17.8c-1.7-.1-3.1-1.4-3.2-3.1V18.1c0-1.9 1.6-3.4 3.5-3.4h16.6c1.8.1 3.2 1.5 3.3 3.2v12.8h.3c4.3-12.3 12.5-18 23.5-18 11.2 0 18.2 5.7 23.2 18 4.3-12.3 14.1-18 24.6-18 7.5 0 15.6 3.1 20.6 10.1 5.6 7.8 4.5 19.1 4.5 29v58.6c0 1.9-1.6 3.4-3.5 3.4H511c-1.8-.1-3.3-1.6-3.3-3.4V60.3c0-3.9.4-13.7-.5-17.4-1.3-6.2-5.1-8-10-8-4.1 0-8.4 2.7-10.2 7.1-1.7 4.4-1.5 11.7-1.5 18.3v34.2c0 1.9-1.6 3.4-3.5 3.4H465c-1.8-.1-3.3-1.6-3.3-3.4l-.1-34.2c0-15.3 2.5-37.7-10.5-37.7-13.2 0-12.7 22-12.7 37.7v34.2c0 1.9-1.5 3.4-3.4 3.4l-.2-.2zM593 14.7c27.4 0 42.2 23.5 42.2 53.4 0 28.9-16.4 51.8-42.2 51.8-26.9 0-41.5-23.5-41.5-52.8 0-29.5 14.8-52.4 41.5-52.4zm.2 19.3c-13.6 0-14.4 18.5-14.4 30.1 0 11.6-.2 36.4 14.2 36.4 14.2 0 14.8-19.9 14.8-32 0-8-.3-17.5-2.9-25.1-2.2-6.5-6.5-9.4-11.7-9.4zm77.3 64.5h-17.7c-1.8-.1-3.3-1.6-3.3-3.4l-.1-77.4c.2-1.7 1.7-3.1 3.5-3.1h16.5c1.6.1 2.9 1.2 3.2 2.7v11.8h.3c5-11.1 12-16.4 24.3-16.4 8 0 15.8 2.9 20.8 10.9 4.7 7.4 4.7 19.9 4.7 28.8v47c-.3 1.6-1.8 2.9-3.5 2.9H703c-1.6-.1-2.9-1.3-3.2-2.9V59c0-12.8 1.8-31.4-10.7-31.4-4.2 0-8 2.8-9.9 7.1-2.4 5.5-2.7 11-2.7 18.3v41.1c0 1.9-1.6 3.4-3.5 3.4h.5zM291 56.8c0 10.4.3 19.1-5 28.4-4.2 7.5-11 12.2-18.5 12.2-10.3 0-16.2-7.8-16.2-19.4 0-22.8 20.4-26.9 39.7-26.9v5.7zm26.9 65c-1.8 1.6-4.3 1.7-6.3.6-8.9-7.4-10.4-10.8-15.3-17.9-14.6 14.9-24.9 19.3-43.9 19.3-22.4 0-39.8-13.8-39.8-41.5 0-21.6 11.7-36.3 28.4-43.5 14.4-6.3 34.6-7.5 50.1-9.2v-3.4c0-6.3.5-13.7-3.2-19.1-3.2-4.8-9.4-6.8-14.8-6.8-10.1 0-19.1 5.2-21.3 15.9-.5 2.4-2.2 4.8-4.7 4.9l-17.2-1.9c-2.3-.5-4.8-2.4-4.1-5.9 4-20.8 22.7-27.1 39.5-27.1 8.6 0 19.8 2.3 26.6 8.8 8.6 8 7.8 18.7 7.8 30.3v27.5c0 8.3 3.4 11.9 6.6 16.3 1.1 1.6 1.4 3.6-.1 4.8l-13 11.4-.3-.5z" />
            </svg>
            Ver na Amazon
          </a>
          {product.mercadoLivreLink && (
            <a
              href={product.mercadoLivreLink}
              target="_blank"
              rel="nofollow sponsored noopener"
              class="flex items-center justify-center gap-2 bg-[#3483FA] hover:bg-[#2968c8] text-white font-bold py-2.5 px-4 rounded-lg transition-all text-sm whitespace-nowrap shadow hover:shadow-md"
            >
              <svg
                width="18"
                height="18"
                viewBox="0 0 32 32"
                xmlns="http://www.w3.org/2000/svg"
                fill="white"
                aria-label="Mercado Livre"
              >
                <path d="M16 0C7.163 0 0 7.163 0 16s7.163 16 16 16 16-7.163 16-16S24.837 0 16 0zm6.063 10.297a.878.878 0 0 1-.063.328c-.922 2.344-3.219 6.375-6 6.375-2.781 0-5.078-4.031-6-6.375a.878.878 0 0 1-.063-.328c0-.484.391-.875.875-.875h10.375c.484 0 .875.391.875.875zM16 25.875c-4.266 0-7.906-2.734-9.344-6.609-.047-.125 0-.266.125-.328l1.969-.984c.156-.078.344-.016.422.125C10.234 20.313 12.953 22 16 22s5.766-1.688 6.828-3.922c.078-.141.266-.203.422-.125l1.969.984c.125.063.172.203.125.328C23.906 23.141 20.266 25.875 16 25.875z" />
              </svg>
              Ver no Mercado Livre
            </a>
          )}
        </div>
      </div>
    ))
  }
</div>

<style>
  .affiliate-table .product-row:last-child {
    border-bottom: none;
  }
</style>
