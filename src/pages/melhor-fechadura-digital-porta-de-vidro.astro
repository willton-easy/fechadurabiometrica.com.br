    badge: "💰 Melhor Custo-Benefício",
    rating: 4.9,
    reviewCount: 3421,
    amazonLink: `https://www.amazon.com.br/Fechadura-Digital-Intelbras-FR-101/dp/B076HWLP7P?tag=${AMAZON_TAG}`,
