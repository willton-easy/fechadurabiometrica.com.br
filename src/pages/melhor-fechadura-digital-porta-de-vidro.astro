    rating: 4.8,
    reviewCount: 654,
    amazonLink: `https://www.amazon.com.br/Fechadura-Digital-Biometria-Elsys-ESF-DE2000B/dp/B0CDD7V7MZ?tag=${AMAZON_TAG}`,
    mercadoLivreLink: "https://www.mercadolivre.com.br/p/MLB34567890",
  },
  {
    position: 4,
    title: "Intelbras MFR 4000 — Smart Lock Wi-Fi com App",
    image: "https://m.media-amazon.com/images/I/61W2h1dXlhL._AC_SL1500_.jpg",
    badge: "⚡ Mais Inteligente",
    rating: 4.6,
    reviewCount: 876,
    amazonLink: `https://www.amazon.com.br/Fechadura-Inteligente-MFR-4000-Intelbras/dp/B0CV5VNQFB?tag=${AMAZON_TAG}`,
