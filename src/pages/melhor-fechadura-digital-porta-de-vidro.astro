  },
  {
    position: 3,
    title: 'Intelbras MFR 4000 — Smart Lock Wi-Fi Biometria + Alexa + Google Home',
    image: 'https://m.media-amazon.com/images/I/61W2h1dXlhL._AC_SL500_.jpg',
    badge: '🤖 Mais Inteligente',
    rating: 4.6,
    reviewCount: 1120,
    amazonLink: `https://www.amazon.com.br/dp/B0CV5VNQFB?tag=${TAG}`,
    mercadoLivreLink: 'https://www.mercadolivre.com.br/p/MLB23456789',
    extraImages: ['https://m.media-amazon.com/images/I/61W2h1dXlhL._AC_SL500_.jpg'],
  },
  {
    position: 4,
    title: 'Intelbras FR 400 — Fechadura Biométrica Wi-Fi (Porta de Madeira)',
    image: 'https://m.media-amazon.com/images/I/51DTd911ugL._AC_SL500_.jpg',
    badge: '💰 Melhor Custo-Benefício Smart',
    rating: 4.7,
    reviewCount: 2341,
    amazonLink: `https://www.amazon.com.br/dp/B07BRXHLKM?tag=${TAG}`,
    mercadoLivreLink: 'https://www.mercadolivre.com.br/p/MLB20399753',
    extraImages: ['https://m.media-amazon.com/images/I/51DTd911ugL._AC_SL500_.jpg'],
  },
  {
