---
import Layout from '~/layouts/PageLayout.astro';
import AffiliateTable from '~/components/AffiliateTable.astro';
import TableOfContents from '~/components/TableOfContents.astro';
import AffiliateButton from '~/components/ui/AffiliateButton.astro';

const metadata = {
  title: 'Melhor Fechadura Digital para Porta de Vidro em 2026 [Top 10 Testadas]',
  description:
    'Qual a melhor fechadura eletrônica para porta de vidro? Analisamos os 10 modelos mais vendidos no Brasil com preços, prós, contras e onde comprar mais barato.',
