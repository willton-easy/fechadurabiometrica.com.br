---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { products } from '../../lib/products';

const title = "Melhores Fechaduras Eletrônicas para Porta de Vidro (2026)";
const description = "Guia completo das melhores fechaduras digitais e biométricas para porta de vidro. Modelos que não exigem furos, ideais para escritórios e varandas.";

// Filtrar produtos que mencionam "vidro" ou são ideais para isso
const glassProducts = products.filter(p => 
  p.name.toLowerCase().includes('vidro') || 
  p.specs.some(s => s.toLowerCase().includes('vidro')) ||
  p.verdict.toLowerCase().includes('vidro')
);
---

<BaseLayout title={title} description={description}>
  <section class="bg-foreground py-16 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="text-4xl md:text-5xl font-extrabold text-primary-foreground mb-6">
        Fechadura Eletrônica para <span class="text-primary">Porta de Vidro</span>
      </h1>
      <p class="text-lg text-primary-foreground/70 leading-relaxed">
        Encontrar a fechadura certa para vidro costumava ser um pesadelo. Em 2026, os novos modelos por pressão e encaixe permitem que você tenha segurança biométrica sem precisar trocar seu vidro temperado.
      </p>
    </div>
  </section>

  <section class="py-16 px-4 max-w-7xl mx-auto">
    <div class="grid gap-12">
      <div class="prose prose-invert max-w-none px-4">
        <h2 class="text-3xl font-bold text-foreground">Por que usar uma fechadura específica para vidro?</h2>
        <p class="text-muted-foreground">
          Portas de vidro (especialmente as de 8mm a 12mm) não permitem furos tradicionais de fechaduras de embutir. Por isso, as <strong>fechaduras eletrônicas para porta de vidro</strong> usam um sistema de "clamping" (pressão) ou exigem apenas o furo padrão de puxador que muitas portas já possuem.
        </p>
        
        <div class="my-8 bg-primary/5 border border-primary/20 rounded-2xl p-6">
          <h3 class="text-xl font-bold text-primary mb-4">O que observar antes de comprar:</h3>
          <ul class="space-y-2 text-muted-foreground">
            <li><strong>Espessura do Vidro:</strong> A maioria suporta entre 8mm e 12mm.</li>
            <li><strong>Tipo de Abertura:</strong> Pivotante ou de Correr? (A de correr exige um gancho especial).</li>
            <li><strong>Lado da Maçaneta:</strong> Verifique se o modelo é ambidestro.</li>
          </ul>
        </div>
      </div>

      <div class="bg-card border border-border rounded-3xl p-8 text-center">
        <h3 class="text-2xl font-bold text-foreground mb-4">Estamos preparando o ranking completo de 2026!</h3>
        <p class="text-muted-foreground mb-6">
          Nossa equipe está terminando os testes com a nova linha da Intelbras e Samsung específica para vidros. 
          Enquanto isso, confira os modelos que já passaram nos nossos testes de resistência.
        </p>
        <a href="/" class="inline-flex items-center gap-2 bg-primary text-primary-foreground px-6 py-3 rounded-xl font-bold hover:bg-primary/90 transition-all">
          Ver Modelos Testados
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
