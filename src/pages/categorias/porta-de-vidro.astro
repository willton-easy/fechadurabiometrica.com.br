---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { products } from '../../lib/products';

const title = "Melhores Fechaduras Eletrônicas para Porta de Vidro (2026)";
const description = "Guia completo das melhores fechaduras digitais e biométricas para porta de vidro. Modelos que não exigem furos, ideais para escritórios e varandas.";

// Filtrar produtos que são específicos para vidro (IDs 12, 13, 14 que acabamos de adicionar)
const glassProducts = products.filter(p => 
  p.id === 12 || p.id === 13 || p.id === 14 ||
  p.name.toLowerCase().includes('vitro') || 
  p.specs.some(s => s.toLowerCase().includes('vidro'))
);
---

<BaseLayout title={title} description={description}>
  <!-- Hero Section -->
  <section class="bg-foreground py-16 px-4 relative overflow-hidden">
    <div class="pointer-events-none absolute inset-0 opacity-10" aria-hidden="true">
      <div class="absolute inset-0" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 1px); background-size: 30px 30px;"></div>
    </div>
    <div class="max-w-4xl mx-auto text-center relative">
      <h1 class="text-4xl md:text-5xl font-extrabold text-primary-foreground mb-6 leading-tight">
        Fechadura Eletrônica para <span class="text-primary italic">Porta de Vidro</span>
      </h1>
      <p class="text-lg text-primary-foreground/70 leading-relaxed max-w-2xl mx-auto">
        Não destrua seu vidro temperado. Em 2026, as melhores opções usam tecnologia de pressão e sobreposição para garantir segurança máxima sem furos.
      </p>
    </div>
  </section>

  <!-- Info Section -->
  <section class="py-12 px-4 max-w-7xl mx-auto border-b border-border">
    <div class="prose prose-invert max-w-none text-center">
      <p class="text-muted-foreground text-sm uppercase font-bold tracking-widest mb-4">Dificuldade KD: 12% (Oportunidade)</p>
      <div class="inline-flex gap-8 flex-wrap justify-center">
        <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span class="text-sm font-semibold">Sem Furos no Vidro</span>
        </div>
        <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span class="text-sm font-semibold">Modelos para Vidro de Correr</span>
        </div>
        <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span class="text-sm font-semibold">Instalação Amadora DIY</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Product Grid -->
  <section class="py-16 px-4 max-w-7xl mx-auto">
    <h2 class="text-3xl font-bold text-foreground mb-10 text-center">Top Modelos Recomendados para Vidro</h2>
    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
      {glassProducts.map(product => (
        <article class="bg-card border border-border rounded-3xl p-6 flex flex-col hover:border-primary/30 transition-all shadow-lg hover:shadow-primary/5">
          <div class={`self-start px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider mb-4 border ${product.badgeColor === 'accent' ? 'bg-accent/10 text-accent border-accent/20' : 'bg-primary/10 text-primary border-primary/20'}`}>
            {product.badge}
          </div>
          <div class="relative h-48 w-full bg-white rounded-2xl p-4 mb-6">
            <a href={product.amazonUrl} target="_blank">
                <img src={product.image} alt={product.name} class="h-full w-full object-contain hover:scale-105 transition-transform" />
            </a>
          </div>
          <h3 class="text-xl font-bold text-foreground mb-3">{product.name}</h3>
          <p class="text-sm text-muted-foreground mb-6 line-clamp-3 italic">"{product.verdict}"</p>
          
          <div class="mb-6 space-y-2">
            {product.specs.slice(0, 3).map(spec => (
                <div class="text-xs flex items-center gap-2 text-foreground/80">
                    <div class="w-1.5 h-1.5 rounded-full bg-primary/40"></div>
                    {spec}
                </div>
            ))}
          </div>

          <div class="mt-auto flex flex-col gap-3">
            <a href={product.amazonUrl} target="_blank" rel="nofollow sponsored" class="w-full bg-[#FF9900] text-black font-bold py-3 rounded-xl text-center text-sm shadow-sm hover:bg-[#FF8A00]">
                Ver Preço na Amazon
            </a>
            <a href={product.mlUrl} target="_blank" rel="nofollow sponsored" class="w-full bg-secondary text-foreground py-3 rounded-xl text-center text-sm border border-border hover:bg-secondary/70">
                Mercado Livre
            </a>
          </div>
        </article>
      ))}
    </div>

    <!-- CTA to Pillar Guide -->
    <div class="mt-16 bg-gradient-to-br from-blue-600 to-primary rounded-3xl p-8 md:p-12 text-center text-white shadow-xl">
        <h3 class="text-2xl md:text-3xl font-extrabold mb-4">Ainda em dúvida de como instalar?</h3>
        <p class="text-white/80 mb-8 max-w-2xl mx-auto leading-relaxed">
            Criamos um guia passo a passo ensinando como escolher e instalar sua fechadura no vidro sem correr o risco de quebrar a porta.
        </p>
        <a href="/guias/melhores-fechaduras-porta-de-vidro-2026" class="inline-flex items-center gap-3 bg-white text-primary px-8 py-4 rounded-2xl font-black text-lg shadow-lg hover:scale-105 transition-all">
            LER GUIA COMPLETO
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
        </a>
    </div>
  </section>
</BaseLayout>
