---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { products } from '../../lib/products';
import ProductCard from '../../components/ProductCard.astro';

const title = "Fechadura para Porta de Vidro: Guia Definitivo de Compra e Instalação (2026)";
const description = "Descubra as melhores fechaduras digitais para portas de vidro temperado, correr ou bater. Modelos sem furos, com biometria e senha. Confira nosso ranking!";

// Filtrar produtos específicos para vidro
const glassProducts = products.filter(p => [1, 2, 3].includes(p.rank) && [12, 13, 15].includes(p.id))
  .sort((a, b) => (a.rank || 0) - (b.rank || 0));
---

<BaseLayout title={title} description={description}>
  <!-- Hero Section (UI/UX Skill: Visual Hierarchy) -->
  <section class="relative bg-foreground py-24 px-4 overflow-hidden">
    <div class="absolute inset-0 opacity-10 bg-[radial-gradient(circle_at_1px_1px,_var(--color-primary)_1px,_transparent_1px)] bg-[size:25px_25px]" aria-hidden="true"></div>
    <div class="max-w-5xl mx-auto text-center relative z-10">
      <span class="inline-block px-4 py-1.5 rounded-full bg-primary/20 text-primary-foreground text-xs font-black uppercase tracking-[0.2em] mb-6 border border-primary/30">
        Especialista em Vidro 2026
      </span>
      <h1 class="text-5xl md:text-7xl font-black text-primary-foreground mb-8 leading-[0.9] tracking-tighter">
        A Fechadura Certa para sua <span class="text-primary italic">Porta de Vidro</span>
      </h1>
      <p class="text-xl text-primary-foreground/70 leading-relaxed max-w-3xl mx-auto font-medium">
        Não comprometa a segurança nem a estética do seu ambiente. Reunimos os modelos líderes que oferecem **biometria e senha** com instalação por pressão de 5 minutos.
      </p>
    </div>
  </section>

  <!-- Hub Content Strategy (SuperPlano Level 2.1) -->
  <main class="max-w-7xl mx-auto px-4 py-20">
    
    <div class="grid lg:grid-cols-[1fr_350px] gap-16">
      
      <!-- Main Content Area -->
      <section class="flex flex-col gap-16">
        
        <!-- Pillar Introduction -->
        <article class="prose prose-neutral dark:prose-invert max-w-none">
          <h2 class="text-3xl font-black text-foreground mb-6">O que muda na Fechadura para Vidro?</h2>
          <p class="text-lg leading-relaxed text-muted-foreground">
            A porta de vidro temperado possui uma particularidade crítica: ela não pode ser alterada após o processo de têmpera. Tentar furar uma porta pronta resultará em sua destruição total. Por isso, a engenharia de fechaduras digitais para esse nicho evoluiu para dois caminhos principais:
          </p>
          <ul class="grid md:grid-cols-2 gap-6 my-10 not-prose list-none p-0">
            <li class="bg-card border border-border p-6 rounded-3xl">
              <span class="block text-primary font-black mb-2 uppercase text-xs tracking-wider">01. Fixação por Pressão</span>
              <p class="text-sm text-muted-foreground">Ideal para vidros virgens. A fechadura "abraça" a folha da porta com borrachas de alta fricção.</p>
            </li>
            <li class="bg-card border border-border p-6 rounded-3xl">
              <span class="block text-primary font-black mb-2 uppercase text-xs tracking-wider">02. Encaixe em Furação Padrão</span>
              <p class="text-sm text-muted-foreground">Perfeito para quem está trocando uma fechadura mecânica antiga que já possui o recorte no vidro.</p>
            </li>
          </ul>
        </article>

        <!-- Featured Products -->
        <section id="ranking" class="scroll-mt-20">
          <div class="flex items-end justify-between mb-10 border-b border-border pb-6">
            <h2 class="text-4xl font-black text-foreground tracking-tighter">Ranking 2026</h2>
            <a href="/guias/melhores-fechaduras-porta-de-vidro-2026" class="text-sm font-bold text-primary hover:underline">Ver guia completo →</a>
          </div>
          
          <div class="flex flex-col gap-10">
            {glassProducts.map(product => (
              <ProductCard product={product as any} />
            ))}
          </div>
        </section>

        <!-- Detailed Buying Guide sections -->
        <article class="prose prose-neutral dark:prose-invert max-w-none bg-secondary/20 p-8 md:p-12 rounded-[40px] border border-border">
          <h2 class="text-4xl font-black mb-8 leading-none">Como Escolher seu Modelo Ideal</h2>
          
          <h3 class="font-bold text-xl mb-4">Portas de Correr: A Armadilha Comum</h3>
          <p>
            A maioria das fechaduras digitais de sobrepor para vidro é projetada para portas de **giro** (bater). Se sua porta desliza para o lado, você precisa obrigatoriamente de um modelo com **fecho em gancho** (bolt-hook). Sem isso, a lingueta não terá onde se prender e a porta poderá ser aberta mesmo "trancada".
          </p>

          <h3 class="font-bold text-xl mt-10 mb-4">Escritório vs. Residência</h3>
          <p>
            Para ambientes corporativos, priorize modelos com **Tag RFID ou App**. Isso facilita a gestão de funcionários sem a necessidade de compartilhar uma senha mestra. Para residências, a **Biometria** é insuperável pela conveniência de não precisar carregar nada além do próprio dedo.
          </p>

          <footer class="mt-12 p-6 bg-primary/10 rounded-2xl border border-primary/20">
            <p class="text-sm font-bold text-primary italic mb-0">
              Dica Pro: Sempre verifique se o modelo escolhido possui entrada Micro-USB ou USB-C de emergência na parte externa. Vidros são transparentes, e você não vai querer ficar preso do lado de fora caso a pilha acabe inesperadamente.
            </p>
          </footer>
        </article>

      </section>

      <!-- Sidebar Architecture (Silo Level 2.1) -->
      <aside class="flex flex-col gap-8">
        
        <div class="sticky top-24 flex flex-col gap-8">
          <!-- Quick Links Silo -->
          <nav class="bg-card border border-border p-8 rounded-3xl shadow-sm">
            <h4 class="text-xs font-black uppercase tracking-widest text-primary mb-6">Explorar Silo de Vidro</h4>
            <ul class="flex flex-col gap-4 list-none p-0 m-0">
              <li><a href="/guias/melhores-fechaduras-porta-de-vidro-2026" class="text-sm font-bold hover:text-primary transition-colors flex items-center justify-between">Melhores de 2026 <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M9 5l7 7-7 7" stroke-width="2" /></svg></a></li>
              <li><div class="text-sm font-medium text-muted-foreground/60 flex items-center justify-between">Como Instalar no Vidro <span class="text-[10px] bg-secondary px-2 rounded">Em breve</span></div></li>
              <li><div class="text-sm font-medium text-muted-foreground/60 flex items-center justify-between">Vidro de Correr vs Giro <span class="text-[10px] bg-secondary px-2 rounded">Em breve</span></div></li>
            </ul>
          </nav>

          <!-- Conversion Widget -->
          <div class="bg-primary p-8 rounded-3xl text-primary-foreground text-center shadow-xl shadow-primary/20">
            <h4 class="font-black text-xl mb-4 leading-tight">Precisa de uma recomendação agora?</h4>
            <p class="text-sm text-primary-foreground/70 mb-6 font-medium">Nossa IA analisou 40 modelos e o vencedor absoluto para vidro é a **Intelbras FR 400**.</p>
            <a href="https://amzn.to/3MQlbGo" target="_blank" class="block w-full bg-white text-primary font-black py-4 rounded-xl text-sm transition-transform hover:scale-105 shadow-md">
              VER PREÇO ATUAL
            </a>
          </div>

          <!-- SEO Keywords Cloud -->
          <div class="text-center">
            <p class="text-[10px] text-muted-foreground/50 uppercase font-bold tracking-widest">Tópicos Relacionados</p>
            <div class="flex flex-wrap justify-center gap-2 mt-2 opacity-40">
              <span class="text-[10px] bg-secondary border border-border px-2 py-0.5 rounded-full">fechadura digital vidro</span>
              <span class="text-[10px] bg-secondary border border-border px-2 py-0.5 rounded-full">biometria porta vidro</span>
              <span class="text-[10px] bg-secondary border border-border px-2 py-0.5 rounded-full">instalação por pressão</span>
            </div>
          </div>
        </div>

      </aside>

    </div>

  </main>
</BaseLayout>

<style>
  .lead { font-weight: 500; }
</style>
