---
import BaseLayout from '../layouts/BaseLayout.astro'
import { products } from '../lib/products'

const tocItems = [
  { label: 'Ranking: Top 15 Fechaduras', href: '#ranking' },
  { label: 'Melhor Custo-Benefício', href: '#produto-3' },
  { label: 'Melhor Premium', href: '#produto-1' },
  { label: 'Melhor com Wi-Fi', href: '#produto-5' },
  { label: 'Guia de Compra', href: '#guia' },
  { label: 'Perguntas Frequentes', href: '#faq' },
  { label: 'Últimas Dicas de Segurança', href: '#ultimas-dicas' },
]

const faqs = [
  {
    question: 'Fechaduras biométricas são seguras?',
    answer:
      'Sim. As fechaduras biométricas modernas utilizam sensores capacitivos ou 3D que são extremamente difíceis de burlar. Além disso, elas contam com sistemas anti-arrombamento, alarmes e criptografia de dados. São consideradas mais seguras que fechaduras mecânicas tradicionais.',
  },
  {
    question: 'E se a bateria acabar e eu estiver do lado de fora?',
    answer:
      'Pânico desnecessário! A fechadura vai te avisar semanas antes com bipes chatos. Mas se você ignorar tudo e ela morrer, basta encostar uma bateria 9V (ou cabo USB, dependendo do modelo) nos contatos externos e digitar sua senha para entrar. É simples assim.',
  },
  {
    question: 'Posso instalar a fechadura biométrica sozinho?',
    answer:
      'Depende do modelo e da sua porta. Modelos mais simples podem ser instalados com ferramentas básicas seguindo o manual. Porém, recomendamos contratar um profissional, especialmente para portas de vidro, pivotantes ou que precisem de adaptações estruturais.',
  },
  {
    question: 'Qual a diferença entre fechadura digital e biométrica?',
    answer:
      'Fechaduras digitais utilizam senhas numéricas e/ou cartões RFID para desbloqueio. Fechaduras biométricas adicionam o reconhecimento por impressão digital ou facial. Toda biométrica é digital, mas nem toda digital é biométrica.',
  },
  {
    question: 'As fechaduras Wi-Fi podem ser hackeadas?',
    answer:
      'As melhores marcas utilizam criptografia AES-128 ou AES-256 e protocolos de segurança avançados. O risco de invasão digital é muito baixo em modelos de marcas reconhecidas. Recomendamos sempre manter o firmware atualizado e usar senhas fortes no app.',
  },
  {
    question: 'Quanto tempo dura a bateria de uma fechadura eletrônica?',
    answer:
      'Em média, de 6 a 12 meses dependendo do modelo e da frequência de uso. Modelos mais avançados com Wi-Fi podem consumir mais. A maioria usa 4 pilhas AA alcalinas, facilmente substituíveis.',
  },
]

const articles = [
  {
    title: 'Como Escolher a Fechadura Biométrica Ideal Para Seu Tipo de Porta',
    excerpt: 'Guia prático com tudo que você precisa saber antes de comprar, desde medidas até compatibilidade.',
    date: '20 Fev 2026',
    readTime: '8 min',
    href: '/guias/como-escolher-fechadura-biometrica',
  },
  {
    title: 'Fechadura Digital vs Biométrica: Qual a Diferença?',
    excerpt: 'Entenda as diferenças técnicas entre os dois tipos e descubra qual faz mais sentido para o seu caso.',
    date: '15 Fev 2026',
    readTime: '6 min',
    href: '/guias/digital-vs-biometrica',
  },
  {
    title: '5 Erros Comuns na Instalação de Fechaduras Eletrônicas',
    excerpt: 'Evite problemas conhecidos que podem comprometer a segurança e a durabilidade do equipamento.',
    date: '10 Fev 2026',
    readTime: '5 min',
    href: '/guias/erros-instalacao',
  },
]

const badgeClass = {
  primary: 'bg-primary/10 text-primary border-primary/20',
  accent: 'bg-accent/10 text-accent border-accent/20',
  cta: 'bg-cta/10 text-cta border-cta/20',
}
---

<BaseLayout
  title="As Melhores Fechaduras Biométricas de 2026 | Ranking e Reviews"
  description="Ranking completo com análises técnicas aprofundadas, testes práticos e comparações detalhadas para você escolher a fechadura eletrônica ideal para sua casa ou empresa em 2026."
>

  <!-- ============================================================ -->
  <!-- HERO SECTION                                                  -->
  <!-- ============================================================ -->
  <section class="relative overflow-hidden bg-foreground py-16 md:py-24">
    <!-- Dot pattern overlay -->
    <div class="pointer-events-none absolute inset-0 opacity-5" aria-hidden="true">
      <div class="absolute inset-0" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 1px); background-size: 40px 40px;"></div>
    </div>

    <div class="relative mx-auto max-w-7xl px-4 lg:px-6">
      <div class="flex flex-col items-center text-center">
        <!-- Badge -->
        <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-primary/30 bg-primary/10 px-4 py-2 text-sm font-medium text-primary">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>
          Testado por Especialistas em 2026
        </div>

        <!-- H1 -->
        <h1 class="max-w-4xl text-3xl font-extrabold tracking-tight text-primary-foreground sm:text-4xl md:text-5xl lg:text-6xl">
          Qual a melhor fechadura biométrica de{' '}
          <span class="bg-gradient-to-r from-primary to-blue-400 bg-clip-text text-transparent">
            2026
          </span>
          ? Testei as que valem o investimento.
        </h1>

        <!-- Subtitle -->
        <p class="mt-5 max-w-2xl text-base leading-relaxed text-primary-foreground/70 md:text-lg">
          Chega de carregar chaves. Se você ainda vive com a dúvida se trancou a porta, 2026 é o ano de resolver isso. Analisei o mercado, filtrei o que é firula e montei este guia prático para você não errar na compra.
        </p>

        <!-- Stats -->
        <div class="mt-10 flex flex-wrap items-center justify-center gap-6 md:gap-10">
          <div class="flex items-center gap-2.5 text-primary-foreground/80">
            <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary/15">
              <svg class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            </div>
            <div class="text-left">
              <p class="text-lg font-bold text-primary-foreground">15+</p>
              <p class="text-xs text-primary-foreground/50">Modelos Testados</p>
            </div>
          </div>
          <div class="flex items-center gap-2.5 text-primary-foreground/80">
            <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary/15">
              <svg class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>
            </div>
            <div class="text-left">
              <p class="text-lg font-bold text-primary-foreground">200+</p>
              <p class="text-xs text-primary-foreground/50">Horas de Testes</p>
            </div>
          </div>
          <div class="flex items-center gap-2.5 text-primary-foreground/80">
            <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-accent/15">
              <svg class="h-5 w-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>
            </div>
            <div class="text-left">
              <p class="text-lg font-bold text-primary-foreground">100%</p>
              <p class="text-xs text-primary-foreground/50">Independente</p>
            </div>
          </div>
        </div>

        <!-- CTA Button -->
        <a
          href="#ranking"
          class="mt-12 inline-flex min-h-[44px] items-center gap-2 rounded-xl bg-primary px-6 py-3 text-sm font-semibold text-primary-foreground shadow-lg shadow-primary/25 transition-all hover:bg-primary/90 hover:shadow-xl hover:shadow-primary/30"
        >
          Ver o Ranking Completo
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- E-E-A-T BOX — Autor                                          -->
  <!-- ============================================================ -->
  <section class="mx-auto max-w-7xl px-4 py-8 lg:px-6">
    <div class="flex flex-col items-center gap-5 rounded-2xl border border-border bg-card p-6 shadow-sm sm:flex-row sm:items-start sm:gap-6 md:p-8">
      <!-- Avatar -->
      <div class="relative flex-shrink-0">
        <div class="flex h-20 w-20 items-center justify-center rounded-full bg-primary/10 text-2xl font-bold text-primary">WA</div>
        <div class="absolute -bottom-1 -right-1 flex h-6 w-6 items-center justify-center rounded-full bg-primary text-primary-foreground">
          <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
      </div>
      <!-- Info -->
      <div class="text-center sm:text-left">
        <div class="flex flex-col items-center gap-2 sm:flex-row">
          <h2 class="text-lg font-bold text-foreground">Willton Alves</h2>
          <span class="rounded-full bg-primary/10 px-3 py-0.5 text-xs font-semibold text-primary">Análise Real</span>
        </div>
        <p class="mt-0.5 text-sm font-medium text-muted-foreground">Apaixonado por segurança e tecnologia residencial</p>
        <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
          Eu não apenas leio manuais. Eu instalo, testo a bateria na prática e vejo se o sensor realmente funciona com o dedo suado ou na correria do dia a dia. Meu objetivo aqui é poupar seu tempo e seu dinheiro, indicando o que realmente presta.
        </p>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- NARRATIVE SECTION                                            -->
  <!-- ============================================================ -->
  <section class="mx-auto max-w-4xl px-4 py-12 lg:px-6 prose prose-invert prose-blue">
    <h2 class="text-3xl font-bold text-foreground">Por que você deveria migrar para a Biometria agora?</h2>
    <p class="text-muted-foreground leading-relaxed">
      Não é só "frescura" tecnológica. O ano de 2026 marcou a chegada da biometria 3D e capacitiva para o grande público. Sabe aquela cena de filme onde o cara encosta o dedo e a porta abre em milissegundos? <strong>Isso agora é a realidade na porta da sua casa.</strong>
    </p>
    <p class="text-muted-foreground leading-relaxed">
      Migrar para uma fechadura biométrica resolve três problemas de uma vez:
    </p>
    <ul class="text-muted-foreground space-y-2">
      <li><strong>Amnésia de chaves:</strong> Você nunca mais vai ficar trancado para fora porque esqueceu o molho na mesa do escritório.</li>
      <li><strong>Controle Total:</strong> Se a diarista ou o encanador chegar e você não estiver, você abre a porta pelo celular ou cria uma senha que só funciona por 2 horas.</li>
      <li><strong>Segurança Real:</strong> É muito mais fácil alguém perder ou clonar uma chave física do que burlar um sensor de impressão digital de última geração.</li>
    </ul>
  </section>

  <!-- ============================================================ -->
  <!-- TABLE OF CONTENTS                                            -->
  <!-- ============================================================ -->
  <nav class="mx-auto max-w-7xl px-4 pb-8 lg:px-6" aria-label="Índice do conteúdo">
    <div class="rounded-2xl border border-border bg-card p-6 shadow-sm">
      <div class="mb-4 flex items-center gap-2.5">
        <svg class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg>
        <h2 class="text-base font-bold text-foreground">Neste Guia</h2>
      </div>
      <ol class="grid gap-1.5 sm:grid-cols-2">
        {tocItems.map((item, idx) => (
          <li>
            <a
              href={item.href}
              class="flex min-h-[44px] items-center gap-3 rounded-lg px-3 py-2 text-sm text-foreground transition-colors hover:bg-secondary hover:text-primary"
            >
              <span class="flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-md bg-primary/10 text-xs font-bold text-primary">
                {idx + 1}
              </span>
              {item.label}
            </a>
          </li>
        ))}
      </ol>
    </div>
  </nav>

  <!-- ============================================================ -->
  <!-- RANKING SECTION                                              -->
  <!-- ============================================================ -->
  <section id="ranking" class="mx-auto max-w-7xl px-4 pb-16 lg:px-6">
    <div class="mb-8 flex items-center gap-3">
      <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-accent/10">
        <svg class="h-5 w-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>
      </div>
      <div>
        <h2 class="text-2xl font-bold text-foreground">Ranking: Top 15 Fechaduras de 2026</h2>
        <p class="text-sm text-muted-foreground">Atualizado em Fevereiro de 2026</p>
      </div>
    </div>

    <div class="flex flex-col gap-6">
      {products.map((product) => (
          <article
            id={`produto-${product.rank}`}
            class="group rounded-2xl border border-border bg-card p-5 shadow-sm transition-shadow hover:shadow-md md:p-6"
            itemscope
            itemtype="https://schema.org/Product"
          >
            <div class="flex flex-col gap-5 lg:flex-row lg:gap-6">
              <!-- Left: image area -->
              <div class="flex flex-col items-center gap-4 lg:w-64 lg:flex-shrink-0">
                <div class="flex items-center gap-3 self-start">
                  <!-- Rank badge -->
                  <div class={`flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-xl text-lg font-extrabold ${product.rank <= 3 ? 'bg-primary text-primary-foreground shadow-md shadow-primary/25' : 'bg-secondary text-muted-foreground'}`}>
                    {product.rank}
                  </div>
                  <span class={`rounded-full border px-3 py-1 text-xs font-semibold ${badgeClass[product.badgeColor]}`}>
                    {product.badge}
                  </span>
                </div>
                <!-- Product image -->
                <div class="relative flex h-56 w-full items-center justify-center overflow-hidden rounded-xl bg-white p-4 lg:h-52 lg:w-60">
                   <img 
                    src={product.image} 
                    alt={product.name}
                    class="h-full w-full object-contain transition-transform duration-300 group-hover:scale-105"
                    loading={product.rank <= 3 ? "eager" : "lazy"}
                  />
                </div>
              </div>

              <!-- Right: content -->
              <div class="flex flex-1 flex-col gap-4">
                <!-- Title -->
                <h3 class="text-xl font-bold text-foreground" itemprop="name">
                  <a href={product.reviewUrl} class="transition-colors hover:text-primary">
                    {product.name}
                  </a>
                </h3>

                <!-- Specs -->
                <div class="flex flex-wrap gap-2">
                  {product.specs.map((spec) => (
                    <span class="rounded-lg bg-secondary px-3 py-1.5 text-xs font-medium text-secondary-foreground">
                      {spec}
                    </span>
                  ))}
                </div>

                <!-- Verdict -->
                <p class="text-sm leading-relaxed text-muted-foreground" itemprop="description">
                  {product.verdict}
                </p>

                <!-- Pros & Cons -->
                <div class="grid gap-4 sm:grid-cols-2">
                  <div>
                    <p class="mb-2 text-xs font-semibold uppercase tracking-wider text-primary">O que gostamos</p>
                    <ul class="flex flex-col gap-1.5">
                      {product.pros.map((pro) => (
                        <li class="flex items-start gap-2 text-sm text-foreground">
                          <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                          {pro}
                        </li>
                      ))}
                    </ul>
                  </div>
                  <div>
                    <p class="mb-2 text-xs font-semibold uppercase tracking-wider text-destructive">Pontos de atenção</p>
                    <ul class="flex flex-col gap-1.5">
                      {product.cons.map((con) => (
                        <li class="flex items-start gap-2 text-sm text-foreground">
                          <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-destructive" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                          {con}
                        </li>
                      ))}
                    </ul>
                  </div>
                </div>

                <!-- CTA Buttons -->
                <div class="flex flex-wrap gap-3 pt-1">
                  <a
                    href={product.amazonUrl}
                    rel="nofollow sponsored"
                    target="_blank"
                    class="inline-flex min-h-[44px] items-center gap-2 rounded-xl bg-cta px-5 py-2.5 text-sm font-semibold text-cta-foreground shadow-sm transition-all hover:bg-cta/90 hover:shadow-md"
                  >
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                    Ver Preço na Amazon
                  </a>
                  <a
                    href={product.mlUrl}
                    rel="nofollow sponsored"
                    target="_blank"
                    class="inline-flex min-h-[44px] items-center gap-2 rounded-xl border border-border bg-card px-5 py-2.5 text-sm font-semibold text-foreground transition-colors hover:bg-secondary hover:text-primary"
                  >
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                    Ver no Mercado Livre
                  </a>
                  <a
                    href={product.reviewUrl}
                    class="inline-flex min-h-[44px] items-center gap-2 rounded-xl px-5 py-2.5 text-sm font-medium text-primary transition-colors hover:bg-primary/5"
                  >
                    Ler Review Completo
                  </a>
                </div>
              </div>
            </div>
          </article>
      ))}
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- FAQ SECTION                                                  -->
  <!-- ============================================================ -->
  <section id="faq" class="mx-auto max-w-7xl px-4 pb-16 lg:px-6">
    <div class="mb-8 flex items-center gap-3">
      <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-primary/10">
        <svg class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      </div>
      <h2 class="text-2xl font-bold text-foreground">Perguntas Frequentes</h2>
    </div>

    <!-- FAQ Schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqs.map(faq => ({
        "@type": "Question",
        "name": faq.question,
        "acceptedAnswer": { "@type": "Answer", "text": faq.answer }
      }))
    })} />

    <div class="rounded-2xl border border-border bg-card shadow-sm divide-y divide-border overflow-hidden">
      {faqs.map((faq, idx) => (
        <details class="group px-6" id={`faq-${idx}`}>
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 py-5 text-sm font-semibold text-foreground transition-colors hover:text-primary [&::-webkit-details-marker]:hidden">
            {faq.question}
            <svg class="h-4 w-4 flex-shrink-0 text-muted-foreground transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="pb-5 text-sm leading-relaxed text-muted-foreground">{faq.answer}</p>
        </details>
      ))}
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- LATEST TIPS SECTION                                          -->
  <!-- ============================================================ -->
  <section id="ultimas-dicas" class="mx-auto max-w-7xl px-4 pb-16 lg:px-6">
    <div class="mb-8 flex items-center gap-3">
      <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-primary/10">
        <svg class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
      </div>
      <h2 class="text-2xl font-bold text-foreground">Últimas Dicas de Segurança</h2>
    </div>

    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {articles.map((article) => (
        <a
          href={article.href}
          class="group flex flex-col rounded-2xl border border-border bg-card p-6 shadow-sm transition-all hover:border-primary/30 hover:shadow-md"
        >
          <h3 class="text-base font-bold text-foreground transition-colors group-hover:text-primary">
            {article.title}
          </h3>
          <p class="mt-2 flex-1 text-sm leading-relaxed text-muted-foreground">
            {article.excerpt}
          </p>
          <div class="mt-4 flex items-center justify-between">
            <div class="flex items-center gap-3 text-xs text-muted-foreground">
              <span>{article.date}</span>
              <span class="flex items-center gap-1">
                <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                {article.readTime}
              </span>
            </div>
            <span class="flex items-center gap-1 text-sm font-medium text-primary opacity-0 transition-opacity group-hover:opacity-100">
              Ler
              <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </span>
          </div>
        </a>
      ))}
    </div>
  </section>

</BaseLayout>
