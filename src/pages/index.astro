  <div id="ml-drawer-overlay" class="fixed inset-0 bg-background/70 backdrop-blur-md z-40 transition-opacity duration-300 opacity-0 pointer-events-none lg:hidden"></div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // DRAWER INTERACTION LOGIC
      const drawer = document.getElementById('ml-bottom-drawer');
      const header = document.getElementById('ml-drawer-header') as HTMLElement;
      const overlay = document.getElementById('ml-drawer-overlay') as HTMLElement;
      const icon = document.getElementById('ml-drawer-icon') as HTMLElement;
      
      if (!drawer || !header || !overlay || !icon) return;

      let isExpanded = false;
      let startY = 0;
      let threshold = 40; // Pixels to drag to trigger state change

      function openDrawer() {
        if (isExpanded) return;
        isExpanded = true;
        drawer!.style.transform = 'translateY(0)';
        icon!.style.transform = 'rotate(180deg)';
        overlay!.classList.remove('pointer-events-none', 'opacity-0');
        document.body.style.overflow = 'hidden'; 
      }

      function closeDrawer() {
        if (!isExpanded) return;
        isExpanded = false;
        drawer!.style.transform = 'translateY(calc(100% - 70px))';
        icon!.style.transform = 'rotate(0deg)';
        overlay!.classList.add('opacity-0');
        document.body.style.overflow = '';
        setTimeout(() => { if (!isExpanded) overlay!.classList.add('pointer-events-none'); }, 300);
      }

      // Tocar em qualquer lugar da gaveta para abrir (quando fechada)
      drawer.addEventListener('click', () => {
        if (!isExpanded) openDrawer();
      });

      // Tocar no header alterna
      header.addEventListener('click', (e) => {
        e.stopPropagation(); // Impede o `drawer click` geral de agir
        if (isExpanded) {
           closeDrawer();
        } else {
           openDrawer();
        }
      });

      // Clicar fora fecha a gaveta
      overlay.addEventListener('click', closeDrawer);

      // GESTOS NO HEADER - Apenas Header controla abertura total ou fechamento firme por swipe.
      let headerStartY = 0;
      header.addEventListener('touchstart', (e) => {
          headerStartY = e.touches[0].clientY;
      }, {passive: true});
      header.addEventListener('touchend', (e) => {
          let delta = e.changedTouches[0].clientY - headerStartY;
          if (isExpanded && delta > 30) closeDrawer();
          if (!isExpanded && delta < -30) openDrawer();
      });

      // GESTOS NA LISTA - Permite fechar a gaveta se arrastar muito pra baixo e já estiver no topo do scroll.
      const scrollArea = drawer.querySelector('.overflow-y-auto') as HTMLElement | null;
      if (scrollArea) {
          let listStartY = 0;
          scrollArea.addEventListener('touchstart', (e) => {
              listStartY = e.touches[0].clientY;
          }, {passive: true});
          scrollArea.addEventListener('touchend', (e) => {
              let delta = e.changedTouches[0].clientY - listStartY;
              if (isExpanded && delta > 50 && scrollArea.scrollTop <= 0) {
                  closeDrawer();
              }
          });
      }

      // --- ML LIVE RANKING DATA FETCH ---
      const liveCards = drawer.querySelectorAll('[data-ml-live-card]');
      liveCards.forEach(async (card) => {
        const mlbId = card.getAttribute('data-ml-live-card');
        const mlUrl = card.getAttribute('data-ml-url');
        const rank = card.getAttribute('data-ml-rank');
        if (!mlbId) return;

        try {
          const res = await fetch(`/api/ml-price?id=${mlbId}&rank=${rank}&url=${encodeURIComponent(mlUrl || "")}`);
          if (!res.ok) {
            hideCardUi(mlbId);
            return;
          }
          
          const data = await res.json();
          const ratingText = document.getElementById(`ml-rating-text-${mlbId}`);
          const ratingContainer = document.getElementById(`ml-rating-container-${mlbId}`);
          
          if (ratingText && data.rating) {
            ratingText.innerText = `${data.rating.toFixed(1)} (${data.reviews_count || 0} avaliações)`;
            ratingText.classList.remove('animate-pulse');
            if (ratingContainer) {
               const stars = ratingContainer.querySelectorAll('svg');
               const score = Math.round(data.rating);
               stars.forEach((star, i) => { if (i < score) star.classList.remove('opacity-20'); });
            }
          } else {
            if (ratingContainer) ratingContainer.style.display = 'none';
          }

          const stockBadge = document.getElementById(`ml-stock-badge-${mlbId}`);
          const stockCount = document.getElementById(`ml-stock-count-${mlbId}`);
          if (stockBadge && stockCount && data.stock !== null && data.stock !== undefined) {
            stockCount.innerText = data.stock;
            stockBadge.style.display = 'inline-flex';
          } else {
            if (stockBadge) stockBadge.style.display = 'none';
          }

        } catch (err) {
          hideCardUi(mlbId);
        }
      });

      function hideCardUi(id: string) {
         const rc = document.getElementById(`ml-rating-container-${id}`);
         const sb = document.getElementById(`ml-stock-badge-${id}`);
         if(rc) rc.style.display = 'none';
         if(sb) sb.style.display = 'none';
      }
    });
  </script>

</BaseLayout>

<style>
  @keyframes float-effect {
    0% {
      transform: translateY(0) scale(1.05);
      filter: drop-shadow(0 4px 6px rgba(0, 0, 0, 0.05));
    }
    50% {
      transform: translateY(-10px) scale(1.05);
      filter: drop-shadow(0 20px 20px rgba(0, 0, 0, 0.15));
    }
    100% {
      transform: translateY(0) scale(1.05);
      filter: drop-shadow(0 4px 6px rgba(0, 0, 0, 0.05));
    }
  }

  .hover-float {
    transform: scale(1); /* Estado inicial */
  }

  /* Quando houver hover no 'article' .group, anima a imagem .hover-float */
  .group:hover .hover-float {
    animation: float-effect 4s ease-in-out infinite;
  }
</style>
