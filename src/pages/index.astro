---
import BaseLayout from '../layouts/BaseLayout.astro'
import { createClient } from '@supabase/supabase-js'

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL || 'https://ahgbxzbyylawrxryyhuc.supabase.co';
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY || 'sb_publishable_R-njGNTmJuGsvlbbsl6_1Q_wnG9xdSJ';
const supabase = createClient(supabaseUrl, supabaseKey);

// Baixando os produtos ordenados (rank)
const { data: dbProducts, error } = await supabase.from('products').select('*').order('rank', { ascending: true });
const products = dbProducts || [];

const tocItems = [
  { label: 'O que é Biometria e por que usar?', href: '#o-que-e-biometria' },
  { label: 'Sensor Óptico vs Semicondutor', href: '#sensores' },
  { label: 'Ranking: As 10 Melhores de 2026', href: '#ranking' },
  { label: 'Análise Detalhada (Reviews)', href: '#reviews' },
  { label: 'Intelbras vs Samsung vs Yale', href: '#marcas' },
  { label: 'Fechadura para Porta de Vidro', href: '#porta-vidro' },
  { label: 'Fechadura para Portão Externo', href: '#portao' },
  { label: 'Guia de Compra', href: '#guia' },
  { label: 'Perguntas Frequentes (FAQ)', href: '#faq' },
]

const faqs = [
  {
    question: 'A fechadura digital pode ser hackeada?',
    answer:
      'Em teoria, qualquer dispositivo eletrônico pode. Na prática, marcas como Yale e Samsung usam criptografia AES de nível militar. É infinitamente mais fácil alguém arrombar uma fechadura mecânica tradicional do que hackear o sistema de uma fechadura de elite em 2026.',
  },
  {
    question: 'E se a bateria acabar e eu estiver do lado de fora?',
    answer:
      'Pânico desnecessário! A fechadura vai te avisar semanas antes com bipes. Mas se você ignorar tudo e ela morrer, basta encostar uma bateria 9V (ou cabo USB, dependendo do modelo) nos contatos externos e digitar sua senha para entrar. É simples assim.',
  },
  {
    question: 'Crianças e idosos conseguem usar a biometria?',
    answer:
      'Sim, mas idosos com digitais muito desgastadas podem ter dificuldade com sensores ópticos. Nesses casos, recomendamos sensores semicondutores (capacitivos) ou o uso de Tags RFID, que acompanham muitos modelos da Intelbras e Pado.',
  },
  {
    question: 'Qual a diferença entre sensor óptico e semicondutor?',
    answer:
      'O óptico tira uma "foto" da digital (como a FR 220), enquanto o semicondutor lê a eletricidade da pele (como na Yale YMF 40A). Semicondutores são mais rápidos, precisos e seguros contra moldes falsos.',
  },
  {
    question: 'Dura quanto tempo a bateria?',
    answer:
      'Depende do uso e se tem Wi-Fi. Em média, 4 pilhas AA duram de 6 a 12 meses. Modelos com Wi-Fi nativo tendem a consumir um pouco mais, por isso alguns usam até 8 pilhas.',
  },
]

const articles = [
  {
    title: 'Como Escolher a Fechadura Biométrica Ideal Para Seu Tipo de Porta',
    excerpt: 'Guia prático com tudo que você precisa saber antes de comprar, desde medidas até compatibilidade.',
    date: '20 Fev 2026',
    readTime: '8 min',
    href: '/guias/como-escolher-fechadura-biometrica',
  },
  {
    title: 'Fechadura Digital vs Biométrica: Qual a Diferença?',
    excerpt: 'Entenda as diferenças técnicas entre os dois tipos e descubra qual faz mais sentido para o seu caso.',
    date: '15 Fev 2026',
    readTime: '6 min',
    href: '/guias/digital-vs-biometrica',
  },
  {
    title: '5 Erros Comuns na Instalação de Fechaduras Eletrônicas',
    excerpt: 'Evite problemas conhecidos que podem comprometer a segurança e a durabilidade do equipamento.',
    date: '10 Fev 2026',
    readTime: '5 min',
    href: '/guias/erros-instalacao',
  },
]

const badgeClass = {
  primary: 'bg-primary/10 text-primary border-primary/20',
  accent: 'bg-accent/10 text-accent border-accent/20',
  cta: 'bg-cta/10 text-cta border-cta/20',
}

function getStarClass(star: number, rating: number): string {
  return star <= Math.round(rating) ? 'text-amber-400' : 'text-gray-300';
}
---

<BaseLayout
  title="As 7 Melhores Fechaduras Biométricas de 2026: Ranking Real e Custo-Benefício"
  description="Ranking completo com análises técnicas aprofundadas, testes práticos e comparações detalhadas para você escolher a fechadura eletrônica ideal para sua casa ou empresa em 2026."
>

  <!-- ============================================================ -->
  <!-- HERO SECTION                                                  -->
  <!-- ============================================================ -->
  <section class="relative overflow-hidden bg-foreground py-16 md:py-24">
    <!-- Dot pattern overlay -->
    <div class="pointer-events-none absolute inset-0 opacity-5" aria-hidden="true">
      <div class="absolute inset-0" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 1px); background-size: 40px 40px;"></div>
    </div>

    <div class="relative mx-auto max-w-7xl px-4 lg:px-6">
      <div class="flex flex-col items-center text-center">
        <!-- Badge -->
        <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-primary/30 bg-primary/10 px-4 py-2 text-sm font-medium text-primary">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>
          Testado por Especialistas em 2026
        </div>

        <!-- H1 -->
        <h1 class="max-w-4xl text-3xl font-extrabold tracking-tight text-primary-foreground sm:text-4xl md:text-5xl lg:text-6xl">
          As 7 Melhores Fechaduras Biométricas de{' '}
          <span class="bg-gradient-to-r from-primary to-blue-400 bg-clip-text text-transparent">
            2026
          </span>
          : Ranking Real e Custo-Benefício
        </h1>

        <!-- Subtitle -->
        <p class="mt-5 max-w-2xl text-base leading-relaxed text-primary-foreground/70 md:text-lg">
          Chega de carregar chaves. Se você ainda vive com a dúvida se trancou a porta, 2026 é o ano de resolver isso. Analisei o mercado, filtrei o que é firula e montei este guia prático para você não errar na compra.
        </p>

        <!-- Stats -->
        <div class="mt-10 flex flex-wrap items-center justify-center gap-6 md:gap-10">
          <div class="flex items-center gap-2.5 text-primary-foreground/80">
            <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary/15">
              <svg class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            </div>
            <div class="text-left">
              <p class="text-lg font-bold text-primary-foreground">15+</p>
              <p class="text-xs text-primary-foreground/50">Modelos Testados</p>
            </div>
          </div>
          <div class="flex items-center gap-2.5 text-primary-foreground/80">
            <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary/15">
              <svg class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>
            </div>
            <div class="text-left">
              <p class="text-lg font-bold text-primary-foreground">200+</p>
              <p class="text-xs text-primary-foreground/50">Horas de Testes</p>
            </div>
          </div>
          <div class="flex items-center gap-2.5 text-primary-foreground/80">
            <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-accent/15">
              <svg class="h-5 w-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>
            </div>
            <div class="text-left">
              <p class="text-lg font-bold text-primary-foreground">100%</p>
              <p class="text-xs text-primary-foreground/50">Independente</p>
            </div>
          </div>
        </div>

        <!-- CTA Button -->
        <a
          href="#ranking"
          class="mt-12 inline-flex min-h-[44px] items-center gap-2 rounded-xl bg-primary px-6 py-3 text-sm font-semibold text-primary-foreground shadow-lg shadow-primary/25 transition-all hover:bg-primary/90 hover:shadow-xl hover:shadow-primary/30"
        >
          Ver o Ranking Completo
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- E-E-A-T BOX — Autor                                          -->
  <!-- ============================================================ -->
  <section class="mx-auto max-w-7xl px-4 py-8 lg:px-6">
    <div class="flex flex-col items-center gap-5 rounded-2xl border border-border bg-card p-6 shadow-sm sm:flex-row sm:items-start sm:gap-6 md:p-8">
      <!-- Avatar -->
      <div class="relative flex-shrink-0">
        <div class="flex h-20 w-20 items-center justify-center rounded-full bg-primary/10 text-2xl font-bold text-primary">WA</div>
        <div class="absolute -bottom-1 -right-1 flex h-6 w-6 items-center justify-center rounded-full bg-primary text-primary-foreground">
          <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
      </div>
      <!-- Info -->
      <div class="text-center sm:text-left">
        <div class="flex flex-col items-center gap-2 sm:flex-row">
          <h2 class="text-lg font-bold text-foreground">Will Alves</h2>
          <span class="rounded-full bg-primary/10 px-3 py-0.5 text-xs font-semibold text-primary">Análise Real</span>
        </div>
        <p class="mt-0.5 text-sm font-medium text-muted-foreground">Apaixonado por segurança e tecnologia residencial</p>
        <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
          Eu não apenas leio manuais. Eu instalo, testo a bateria na prática e vejo se o sensor realmente funciona com o dedo suado ou na correria do dia a dia. Meu objetivo aqui é poupar seu tempo e seu dinheiro, indicando o que realmente presta.
        </p>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- NARRATIVE SECTION — O QUE É BIOMETRIA                      -->
  <!-- ============================================================ -->
  <section id="o-que-e-biometria" class="mx-auto max-w-4xl px-4 py-12 lg:px-6 prose prose-invert prose-blue">
    <h2 class="text-3xl font-bold text-foreground">O que é uma Fechadura Biométrica e por que ela é o futuro da Segurança?</h2>
    <p class="text-muted-foreground leading-relaxed text-lg">
      Não é só "frescura" tecnológica. O ano de 2026 marcou a chegada da biometria 3D e capacitiva para o grande público. Sabe aquela cena de filme onde o cara encosta o dedo e a porta abre em milissegundos? <strong>Isso agora é a realidade na porta da sua casa.</strong>
    </p>
    <p class="text-muted-foreground leading-relaxed">
      Uma <strong>fechadura biométrica</strong> é, em essência, uma fechadura digital que utiliza características biológicas únicas — como sua impressão digital ou reconhecimento facial — para liberar o acesso. No entanto, em 2026, ela se tornou muito mais do que um gadget de luxo. 
    </p>
    <p class="text-muted-foreground leading-relaxed">
       Diferente da <strong>fechadura eletrônica</strong> convencional, que depende apenas de senhas numéricas, a biometria elimina o risco de alguém observar você digitando o código. É o padrão ouro de conveniência: sua chave é o seu dedo, e ela está sempre com você.
    </p>
    <div class="my-8 rounded-xl bg-primary/5 p-6 border border-primary/10">
      <h3 class="text-xl font-semibold text-primary mb-4">Por que migrar agora?</h3>
      <ul class="text-muted-foreground space-y-3">
        <li><strong class="text-foreground">Conveniência Extrema:</strong> Imagine chegar com as mãos ocupadas por sacolas e abrir a porta em menos de 0.3 segundos com apenas um toque.</li>
        <li><strong class="text-foreground">Gestão via Smartphone:</strong> A maioria dos modelos agora se integra nativamente ao Wi-Fi, permitindo gerar senhas temporárias para visitas ou prestadores de serviço à distância.</li>
        <li><strong class="text-foreground">Segurança Reforçada:</strong> Sensores de alta precisão impedem o uso de moldes de silicone ou fotos, garantindo que apenas dedos "vivos" destravem o sistema.</li>
        <li><strong class="text-foreground">Integração com Alexa:</strong> "Alexa, a porta da frente está trancada?" virou um comando padrão.</li>
      </ul>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- TECHNICAL SECTION — SENSORES                                -->
  <!-- ============================================================ -->
  <section id="sensores" class="mx-auto max-w-4xl px-4 py-12 lg:px-6">
    <div class="rounded-3xl border border-border bg-card p-8 shadow-sm">
      <h2 class="text-3xl font-bold text-foreground mb-6">Sensor Óptico vs Semicondutor: Qual o mais seguro?</h2>
      <p class="text-muted-foreground mb-8">
        Se você busca a <strong>melhor fechadura digital com biometria</strong>, precisa entender o que está "sob o capô". Existem dois tipos principais de sensores no mercado hoje:
      </p>
      
      <div class="grid gap-8 md:grid-cols-2">
        <div class="flex flex-col gap-4">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-blue-500/10 text-blue-500">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-foreground">Sensores Ópticos</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">
            Funcionam como uma câmera que tira uma foto da sua digital. São comuns em modelos de entrada (como a Intelbras FR 220). São robustos, mas podem ser "enganados" por moldes de altíssima qualidade.
          </p>
        </div>
        <div class="flex flex-col gap-4">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-orange-500/10 text-orange-500">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-foreground">Sensores Semicondutores (Capacitivos)</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">
            Medem a corrente elétrica da sua pele. São os mesmos usados nos smartphones de elite. São virtualmente impossíveis de burlar. <strong>Em 2026, este é o padrão recomendado.</strong>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- TABLE OF CONTENTS                                            -->
  <!-- ============================================================ -->
  <nav class="mx-auto max-w-7xl px-4 pb-12 lg:px-6" aria-label="Índice do conteúdo">
    <div class="rounded-2xl border border-border bg-card p-6 shadow-sm">
      <div class="mb-4 flex items-center gap-2.5">
        <svg class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg>
        <h2 class="text-base font-bold text-foreground">O que você vai ler:</h2>
      </div>
      <ol class="grid gap-1.5 sm:grid-cols-2 lg:grid-cols-3">
        {tocItems.map((item, idx) => (
          <li>
            <a
              href={item.href}
              class="flex min-h-[44px] items-center gap-3 rounded-lg px-3 py-2 text-sm text-foreground transition-colors hover:bg-secondary hover:text-primary"
            >
              <span class="flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-md bg-primary/10 text-xs font-bold text-primary">
                {idx + 1}
              </span>
              {item.label}
            </a>
          </li>
        ))}
      </ol>
    </div>
  </nav>

  <!-- ============================================================ -->
  <!-- RANKING SECTION                                              -->
  <!-- ============================================================ -->
  <section id="ranking" class="mx-auto max-w-7xl px-4 pb-16 lg:px-6">
    <div class="mb-8 flex items-center gap-3">
      <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-accent/10">
        <svg class="h-5 w-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>
      </div>
      <div>
        <h2 class="text-2xl font-bold text-foreground">O Ranking Definitivo: Melhores de 2026</h2>
        <p class="text-sm text-muted-foreground">O ranking abaixo reflete o equilíbrio entre durabilidade, segurança e integração (Alexa/Google).</p>
      </div>
    </div>

    <div class="flex flex-col gap-6">
      {products.map((product) => (
          <article
            id={`produto-${product.rank}`}
            class="group rounded-2xl border border-border bg-card p-5 shadow-sm transition-shadow hover:shadow-md md:p-6"
            itemscope
            itemtype="https://schema.org/Product"
          >
            <div class="flex flex-col gap-5 lg:flex-row lg:gap-6">
              <!-- Left: image area -->
              <div class="flex flex-col items-center gap-4 lg:w-64 lg:flex-shrink-0">
                <div class="flex items-center gap-3 self-start">
                  <!-- Rank badge -->
                  <div class={`flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-xl text-lg font-extrabold ${product.rank <= 3 ? 'bg-primary text-primary-foreground shadow-md shadow-primary/25' : 'bg-secondary text-muted-foreground'}`}>
                    {product.rank}
                  </div>
                  <span class={`rounded-full border px-3 py-1 text-xs font-semibold ${badgeClass[product.badgeColor as keyof typeof badgeClass] || badgeClass.primary}`}>
                    {product.badge}
                  </span>
                </div>
                <!-- Product image -->
                <a 
                  href={product.amazonUrl} 
                  target="_blank" 
                  rel="nofollow sponsored"
                  class="relative flex h-56 w-full items-center justify-center overflow-hidden rounded-xl bg-white p-4 lg:h-52 lg:w-60 transition-all hover:ring-2 hover:ring-primary/20"
                  aria-label={`Ver ${product.name} na Amazon`}
                >
                   <img 
                    src={product.image} 
                    alt={product.name}
                    class="h-full w-full object-contain transition-all duration-300 hover-float cursor-pointer"
                    loading={product.rank <= 3 ? "eager" : "lazy"}
                  />
                </a>
              </div>

              <!-- Right: content -->
              <div class="flex flex-1 flex-col gap-4">
                <!-- Title -->
                <h3 class="text-xl font-bold text-foreground" itemprop="name">
                  <a href={product.reviewUrl} class="transition-colors hover:text-primary">
                    {product.name}
                  </a>
                </h3>

                <!-- Rating estático do ML -->
                {product.rating && (
                  <div class="flex items-center gap-2">
                    <div class="flex items-center gap-0.5">
                      {[1, 2, 3, 4, 5].map((star: number) => (
                        <svg class={`w-4 h-4 flex-shrink-0 fill-current ${getStarClass(star, product.rating)}`} viewBox="0 0 20 20">
                          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                        </svg>
                      ))}
                    </div>
                    <span class="text-xs font-semibold text-foreground">{product.rating.toFixed(1)}</span>
                    {product.reviews_count && (
                      <span class="text-xs text-muted-foreground">({product.reviews_count.toLocaleString('pt-BR')} avaliações no ML)</span>
                    )}
                  </div>
                )}

                <!-- Specs -->
                <div class="flex flex-wrap gap-2">
