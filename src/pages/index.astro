---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Glossary from '~/components/widgets/Glossary.astro';

import { glossaryItems } from '~/data/glossary';

const metadata = {
  title: 'Fechadura Biométrica - Tudo sobre Fechaduras Digitais Premium',
  description: 'Descubra a melhor fechadura biométrica para porta de vidro e madeira. Análises e tendências tecnológicas de 2026 para proteger sua casa de forma inteligente.',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- JSON-LD para SEO Oficial -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Fechadura Biométrica",
    "url": "https://www.fechadurabiometrica.com.br",
    "description": "Guias, análises e comparativos de fechaduras digitais 2026."
  })} />

  <!-- JSON-LD Estruturado para o Glossário (Rich Snippets) -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": glossaryItems.map(item => ({
      "@type": "Question",
      "name": `O que é ${item.title}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": item.description
      }
    }))
  })} />

  <!-- Hero Widget - Minimalista e Convergente -->
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Ler os Guias Premium',
        href: '/blog',
        icon: 'tabler:book',
      },
      { text: 'Ir para o Glossário', href: '#glossario', icon: 'tabler:bulb' },
    ]}
    image={{ src: '~/assets/images/hero-image.png', alt: 'Fechadura Biométrica de Luxo', fetchpriority: 'high' }}
  >
    <Fragment slot="title">
      Casa Inteligente e Segura: <span class="text-accent dark:text-white">A Revolução Digital 2026</span>
    </Fragment>

    <Fragment slot="subtitle">
      <span class="hidden sm:inline">
        Guias de bolso e análises completas para escolher sua fechadura digital ideal.
      </span>
      Esqueça as chaves de vez. Proteja sua fortaleza com biometria.
    </Fragment>
  </Hero>

  <!-- Features - O que importa -->
  <Features
    id="features"
    tagline="Pilares da Proteção"
    title="O fim da insegurança e das chaves perdidas"
    subtitle="Design moderno, usabilidade premium e segurança de nível militar."
    items={[
      {
        title: 'Criptografia e Biometria',
        description: 'Sensores capacitivos anti-falsificação (3D FaceID) e comunicação AES-128 para evitar qualquer invasão digital ou clonagem.',
        icon: 'tabler:fingerprint',
      },
      {
        title: 'Casa Inteligente Integrada',
        description: 'Compatibilidade total com o protocolo Matter 2026, Zigbee e Wi-Fi (Alexa, Google Home e Apple HomeKit).',
        icon: 'tabler:smart-home',
      },
      {
        title: 'Acabamento Sem Furar',
        description: 'Seja em portas de vidro temperado ou pivotantes de madeira maciça de luxo, instalação sob medida para valorizar o design.',
        icon: 'tabler:door',
      },
    ]}
  />

  <!-- Seção de Silos 2026 - Segurança Além da Porta -->
  <Features
    id="silos-2026"
    tagline="Expansão 2026"
    title="Segurança Além da Porta"
    subtitle="Proteção completa para seu veículo, seu perímetro e sua família."
    items={[
      {
        title: 'Rastreadores Veiculares',
        description: 'Monitore seu carro ou moto sem mensalidades fixas. Tecnologia 4K e GPS de alta precisão.',
        icon: 'tabler:car',
        callToAction: { text: 'Ver Guia', href: '/melhor-rastreador-veicular-sem-mensalidade-2026' }
      },
      {
        title: 'Cercas Elétricas Wi-Fi',
        description: 'Proteção perimetral inteligente com alertas em tempo real no seu smartphone.',
        icon: 'tabler:fence',
        callToAction: { text: 'Ver Guia', href: '/cerca-eletrica-residencial-wifi-kit-completo' }
      },
      {
        title: 'Câmeras Dashcam',
        description: 'Segurança jurídica no trânsito com gravação 4K e modo estacionamento 24h.',
        icon: 'tabler:video',
        callToAction: { text: 'Ver Guia', href: '/melhores-cameras-veiculares-dashcam-2026' }
      },
      {
        title: 'Babás Eletrônicas',
        description: 'Vigilância infantil com visão noturna e áudio bidirecional para tranquilidade total.',
        icon: 'tabler:baby-carriage',
        callToAction: { text: 'Ver Guia', href: '/melhores-babas-eletronicas-wifi-camera-2026' }
      },
    ]}
  />

  <!-- Artigos Atuais -->
  <BlogLatestPosts
    title="Nossa Inteligência Editorial"
    information="O que testamos e aprendemos recentemente sobre as tecnologias de controle de acesso mais requisitadas pelo mercado de alto padrão brasileiro."
    count={8}
  />

  <!-- FAQs - Melhorado para conversão -->
  <FAQs
    title="Dúvidas Clássicas dos Usuários"
    subtitle="Direto ao ponto, sem termos técnicos confusos."
    tagline="FAQs"
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: 'E se faltar energia mecânica e elétrica na rua?',
        description: 'Nenhum problema. Todas as fechaduras são alimentadas por pilhas alcalinas tipo AA independentes. Elas avisam sobre pilhas fracas com meses de antecedência. Caso você negligencie o aviso, você ainda conta com chave de emergência ou cabo USB (powerbank).',
      },
      {
        title: 'Por que o modelo para Porta de Vidro é diferente?',
        description: 'Portas de vidro geralmente não suportam maquinário para cortar um miolo (embutir). Por isso, as fechaduras de porta de vidro usam fitas adesivas de classe estrutural 3M VHB ou fixadores de pressão U-Clip, preservando o vidro intacto.',
      },
      {
        title: 'Qualquer hacker ou inteligência artificial consegue clonar a senha?',
        description: 'As fechaduras de 2026 utilizam senhas dinâmicas (OTP) e os modelos biométricos utilizam sensores de detecção de vivacidade. Ou seja, até dedos de silicone não conseguem enganar os escâneres da Intelbras ou Yale.',
      },
    ]}
  />

  <!-- Glossário Estratégico -->
  <Glossary />
</Layout>
