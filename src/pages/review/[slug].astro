---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import RecentArticles from "../../components/RecentArticles.astro";
import VeredictBox from "../../components/VeredictBox.astro";
import TableOfContents from "../../components/TableOfContents.astro";
import FAQxSchema from "../../components/FAQxSchema.astro";
import SidebarOfferWidget from "../../components/SidebarOfferWidget.astro";
import { products } from "../../lib/products";

// 1. Gera as páginas dinamicamente baseando-se nos arquivos Markdown em src/content/reviews/
export async function getStaticPaths() {
  const reviewEntries = await getCollection("reviews");
  
  return reviewEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

// 2. Extrai as propriedades e o renderizador para Markdown
const { entry } = Astro.props;
const { Content, headings } = await entry.render();

// 3. Flexibilidade: Busca os dados do arquivo TS (antigo) ou usa o novo Frontmatter
let product;

if (entry.data.idProduto) {
  product = products.find((p) => p.id === entry.data.idProduto);
  if (!product) throw new Error(`⚠ Produto com ID ${entry.data.idProduto} não encontrado!`);
} else {
  // Se for o novo padrão do Crawler (CMS-less), mapeia-se uma "Mock Store"
  product = {
    id: Math.floor(Math.random() * 1000) + 100, // ID Fake pra sidebar
    name: entry.data.title || "Fechadura",
    brand: "Geral",
    image: entry.data.heroImage || "",
    verdict: entry.data.description || "Review de Fechadura",
    pros: [], // Prós e contras foram movidos pro corpo do texto da Skill
    cons: [],
    amazonUrl: entry.data.affiliateLink || "",
    mlUrl: "",
  };
}

// SEO Tags e Dados da Página vazios resolvidos
const title = entry.data.title || entry.data.titulo || "Análise de Fechadura";
const description = entry.data.description || product.verdict.replaceAll('*', '');
const heroSubtitle = entry.data.heroSubtitle ? entry.data.heroSubtitle.replaceAll('*', '') : "Avaliação em Foco";

// Dados E-E-A-T (SEO Avançado)
const author = entry.data.author || "Will Alves";
const datePublishedObj = new Date(entry.data.datePublished || '2026-02-15T10:00:00Z');
const dateModifiedObj = new Date(entry.data.dateModified || '2026-03-04T14:30:00Z');
const datePublished = datePublishedObj.toISOString();
const dateModified = dateModifiedObj.toISOString();
const displayDate = new Intl.DateTimeFormat('pt-BR', { month: 'long', year: 'numeric' }).format(dateModifiedObj);

const ICON_PATHS = [
   "M12 11c0 3.517-1.009 6.799-2.753 9.571m-3.44-2.04l.054-.09A13.916 13.916 0 008 11a4 4 0 118 0c0 1.017-.07 2.019-.203 3m-2.118 6.844A21.88 21.88 0 0015.171 17m3.839 1.132c.645-2.266.99-4.659.99-7.132A8 8 0 008 4.07M3 15.364c.64-1.319 1-2.8 1-4.364 0-1.457.39-2.823 1.07-4",
   "M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z",
   "M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z",
   "M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"
];

const schemaData = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": product.name,
  "description": product.verdict.replaceAll('*', ''),
  "image": `https://fechadurabiometrica.com.br${product.image}`,
  "brand": { "@type": "Brand", "name": product.brand || "Desconhecida" },
  "review": {
    "@type": "Review",
    "reviewRating": { "@type": "Rating", "ratingValue": "4.8", "bestRating": "5" },
    "author": { "@type": "Person", "name": author },
    "datePublished": datePublished,
    "dateModified": dateModified,
    "publisher": { "@type": "Organization", "name": "Fechadura Biométrica Brasil" }
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.8",
    "reviewCount": "184"
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Início", "item": "https://fechadurabiometrica.com.br" },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://fechadurabiometrica.com.br/blog" },
    { "@type": "ListItem", "position": 3, "name": product.name, "item": `https://fechadurabiometrica.com.br/review/${entry.slug}` }
  ]
};

const schemaJson = JSON.stringify([schemaData, breadcrumbSchema]);

---

<BaseLayout 
  title={title} 
  description={description} 
  ogTitle={title} 
  ogDescription={description}
  author={author}
  datePublished={datePublished}
  dateModified={dateModified}
>
  <!-- HERO Premium (Landing Page Vibe) -->
  <section class="relative bg-black pt-24 pb-32 px-4 overflow-hidden rounded-b-[4rem]">
    <!-- Background Decorators -->
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-neutral-800/40 via-black to-black"></div>
    <div class="absolute right-0 top-1/2 w-[500px] h-[500px] bg-blue-500/10 rounded-full blur-[120px] pointer-events-none -translate-y-1/2"></div>
    
    <div class="max-w-6xl mx-auto relative z-10 grid lg:grid-cols-2 gap-12 items-center">
      <div class="text-center lg:text-left">
        <!-- Badge -->
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/10 text-white border border-white/20 text-xs font-black uppercase tracking-[0.2em] mb-6 backdrop-blur-sm shadow-xl">
          <span class="w-2 h-2 rounded-full bg-blue-400 animate-pulse"></span>
          Review Masterclass
        </span>
                <!-- Meta details: Author and Date -->
          <div class="flex items-center justify-center lg:justify-start gap-4 text-sm text-neutral-400 mb-8 mt-4">
            <span class="flex items-center gap-1.5">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
              Por {author}
            </span>
            <span class="w-1 h-1 rounded-full bg-neutral-600"></span>
            <span class="flex items-center gap-1.5">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
              Atualizado em {displayDate}
            </span>
          </div>

          <!-- Description -->
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-white mb-6 leading-tight tracking-tighter" itemprop="name">
          {title.split(':').map((linha, idx) => (
             <Fragment key={idx}>
                <span class={idx === 1 ? "text-transparent bg-clip-text bg-gradient-to-r from-blue-300 to-emerald-400 italic" : ""}>
                   {linha.replaceAll('*', '')}
                </span>
                {idx === 0 && title.includes(':') && <br/>}
             </Fragment>
          ))}
        </h1>
        
        <p class="text-lg text-white/70 mb-10 max-w-xl mx-auto lg:mx-0 font-medium leading-relaxed" itemprop="description">
          {heroSubtitle} — {product.verdict.replaceAll('*', '')}
        </p>
        
        <!-- Affiliate Buttons Mobile Standard -->
        <div class="bg-white/5 backdrop-blur-md border border-white/10 p-6 sm:p-8 rounded-3xl inline-block w-full max-w-md shadow-2xl">
           <p class="text-white/80 font-black mb-5 text-sm uppercase tracking-widest text-center">Escolha Onde Comprar:</p>
           <div class="grid grid-cols-2 gap-4">
              <a href={product.mlUrl} target="_blank" rel="nofollow sponsored" class="flex flex-col items-center justify-center gap-2 bg-[#FFE600] text-[#2d3277] font-black p-4 rounded-2xl shadow-lg hover:scale-105 transition-all">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 48 48"><ellipse cx="24" cy="24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" rx="19.5" ry="12.978"/><path fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="M9.704 15.53a20.8 20.8 0 0 0 6.386 1.866a23 23 0 0 0 4.546-.773"/><path fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="M38.882 15.614a8.6 8.6 0 0 1-5.165 1.485c-3.335 0-6.225-2.199-9.215-2.199c-2.668 0-7.189 4.373-7.189 5.164s1.31 1.26 2.372.74c.621-.303 3.31-2.914 5.484-2.914s9.219 7.136 9.857 7.806c.989 1.038-.926 3.274-2.149 2.05s-3.41-3.162-3.41-3.162"/><path fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="M43.4 22.683a24 24 0 0 0-8.547 2.692m-2.273 2.081c.989 1.037-.926 3.273-2.149 2.05s-2.581-2.513-2.581-2.513"/><path fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="M30.135 29.215c.988 1.037-.927 3.273-2.15 2.05s-2.025-1.962-2.025-1.962"/><path fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="M24.202 31.316a2.31 2.31 0 0 0 3.648-.186"/><path fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2.5" stroke-linejoin="round" d="M24.202 31.316c.53-.697.49-3.182-2.244-2.688c.642-1.219.066-3.146-2.388-2.01a1.69 1.69 0 0 0-3.146-.658a1.455 1.455 0 0 0-2.8-.28c-.544 1.104.296 3.096 2.092 1.976c-.182 1.944.84 2.537 2.684 1.78c.099 1.91 1.367 1.745 2.273 1.3a1.938 1.938 0 0 0 3.529.58"/><path fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="M4.67 22.279a18.3 18.3 0 0 1 9.064 3.214"/></svg>
              <span class="text-[10px] sm:text-xs text-center leading-tight">MERCADO<br>LIVRE</span>
              </a>
              <a href={product.amazonUrl} target="_blank" rel="nofollow sponsored" class="flex flex-col items-center justify-center gap-2 bg-[#FF9900] text-black border border-[#FF9900] hover:bg-[#E68A00] font-black p-4 rounded-2xl hover:scale-105 transition-all">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24"><path fill="currentColor" d="M21.997 18.23c0 .727-.405 2.127-1.315 2.896c-.182.14-.364.061-.284-.143c.265-.648.871-2.147.587-2.492c-.201-.262-1.031-.242-1.739-.182c-.323.041-.607.06-.827.105c-.204.016-.245-.163-.041-.303a3.1 3.1 0 0 1 .87-.428c1.15-.344 2.479-.137 2.67.083c.036.042.079.16.079.463m-1.922 1.294a7 7 0 0 1-.829.55c-2.122 1.275-4.871 1.943-7.258 1.943c-3.843 0-7.28-1.417-9.888-3.788c-.224-.182-.039-.446.223-.303c2.81 1.64 6.288 2.632 9.888 2.632c2.266 0 4.708-.424 7.035-1.336c.163-.061.345-.144.504-.202c.367-.165.69.242.325.504m-6.17-11.03c0-1.041.042-1.654-.303-2.18c-.306-.433-.833-.693-1.569-.652c-.798.044-1.655.567-1.873 1.526c-.043.22-.171.436-.437.483l-2.435-.31c-.174-.04-.439-.173-.352-.521C7.459 4.088 9.81 3.129 12.034 3h.522c1.22 0 2.788.349 3.791 1.264c1.217 1.136 1.087 2.662 1.087 4.32v3.927c0 1.178.478 1.7.958 2.314c.13.219.175.477-.044.655a78 78 0 0 1-1.917 1.654c-.175.133-.489.147-.61.045c-.77-.645-.958-1.003-1.435-1.658c-.83.871-1.527 1.352-2.356 1.613a7 7 0 0 1-1.784.216c-2.09 0-3.745-1.303-3.745-3.88c0-2.049 1.09-3.442 2.7-4.101c1.61-.66 3.95-.87 4.704-.874m-.477 5.192c.52-.872.477-1.586.477-3.185c-.652 0-1.306.045-1.871.178c-1.045.303-1.875.96-1.875 2.355c0 1.09.568 1.832 1.526 1.832q.198 0 .348-.045c.67-.186 1.088-.522 1.395-1.135"/></svg>
                <span class="text-[10px] sm:text-xs text-center leading-tight">VER NA<br>AMAZON</span>
              </a>
           </div>
           <p class="text-[10px] mt-4 opacity-50 text-center uppercase tracking-widest">Os valores tendem a oscilar diariamente no site do anunciante.</p>
        </div>
      </div>
      
      <!-- Premium Hero Image -->
      <div class="relative w-full h-full flex flex-col items-center justify-center mt-12 lg:mt-0">
         <img src={product.image} alt={`Review ${product.name}`} class="relative z-10 w-full max-w-[350px] object-contain drop-shadow-[0_20px_50px_rgba(255,255,255,0.15)] transform -rotate-[5deg] hover:rotate-0 hover:scale-105 transition-all duration-700" itemprop="image" />
      </div>
    </div>
  </section>

  <!-- ESPECIFICAÇÕES INFOGRÁFICO Dinâmico -->
  {product.specs && product.specs.length > 0 && (
  <section class="max-w-6xl mx-auto px-4 -mt-20 relative z-20">
    <div class="bg-card border border-border rounded-[2.5rem] p-8 md:p-12 shadow-[0_20px_60px_-15px_rgba(0,0,0,0.1)]">
      <h2 class="text-2xl font-black mb-10 text-center uppercase tracking-widest text-muted-foreground">O que faz dela uma Premium?</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        {(product.specs || []).slice(0, 4).map((spec, i) => (
           <div class="flex flex-col items-center group">
              <div class="w-20 h-20 bg-secondary/50 rounded-3xl flex items-center justify-center mb-5 text-primary group-hover:bg-primary group-hover:text-primary-foreground transition-colors duration-300">
                <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={ICON_PATHS[i%4]} /></svg>
              </div>
              <h4 class="font-black text-foreground text-lg">{spec.replaceAll('*', '')}</h4>
              <p class="text-sm text-muted-foreground mt-1 font-medium">Equipamento Certificado</p>
           </div>
        ))}
      </div>
      <div class="grid sm:grid-cols-2 gap-4 mt-12 bg-secondary/20 rounded-[2rem] p-4">
         <div class="rounded-3xl border border-border bg-card p-4 flex flex-col gap-3 items-center justify-center overflow-hidden text-center">
             <img src="/images/icons/icon_emergency_key.png" alt="Chave Mecânica de Emergência Oculta" class="max-h-[160px] object-contain hover:scale-110 transition-transform duration-500 rounded-2xl" />
             <span class="text-sm font-bold text-muted-foreground uppercase tracking-wider">Acabamento e Engenharia Física de Topo</span>
         </div>
         <div class="rounded-3xl border border-border bg-card p-4 flex flex-col gap-3 items-center justify-center overflow-hidden text-center">
             <img src="/images/icons/icon_fingerprint_sensor.png" alt="Sensor de Biometria Super Rápido Yale" class="max-h-[160px] object-contain hover:scale-110 transition-transform duration-500 rounded-2xl" />
             <span class="text-sm font-bold text-muted-foreground uppercase tracking-wider">Sensores de Alta Performance</span>
         </div>
      </div>
    </div>
  </section>
  )}

  <!-- VeredictBox: Veredito Rápido (Featured Snippet) -->
  {product.buyIf && product.buyIf.length > 0 && (
  <VeredictBox
    productName={product.name}
    rating={product.rating}
    reviewsCount={product.reviewsCount}
    buyIf={product.buyIf}
    avoidIf={product.avoidIf}
    amazonUrl={product.amazonUrl}
    mlUrl={product.mlUrl}
  />
  )}

  <div class="mx-auto max-w-7xl px-4 lg:px-8 py-8 lg:py-16 flex flex-col lg:flex-row gap-10 lg:gap-16">
    <!-- Coluna de Leitura (Esquerda no Desktop) -->
    <div class="flex-1 min-w-0 max-w-4xl mx-auto lg:mx-0">
      <article itemscope itemtype="https://schema.org/Product">
    <!-- Breadcrumb com link para Blog -->
    <nav class="mb-6 flex flex-wrap items-center gap-1.5 text-sm text-muted-foreground" aria-label="Caminho de navegação">
      <a href="/" class="hover:text-primary transition-colors">Home</a>
      <svg class="h-3.5 w-3.5 text-muted-foreground/50" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      <a href="/blog/" class="hover:text-primary transition-colors">Blog</a>
      <svg class="h-3.5 w-3.5 text-muted-foreground/50" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      <span class="text-foreground font-semibold truncate max-w-[200px] sm:max-w-none">{product.name}</span>
    </nav>
    <!-- Data de atualização visível -->
    <p class="mb-6 text-xs text-muted-foreground flex items-center gap-1.5">
      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
      Atualizado em Março de 2026 &middot; Review por Willton Alves
    </p>

    <!-- Índice com âncoras (TOC) -->
    <TableOfContents headings={headings} />

    <div class="prose prose-lg prose-neutral dark:prose-invert max-w-none mb-16 text-lg" style="font-family: 'Inter', sans-serif;">
       <Content />
    </div>

    <!-- Prós e Contras (Renderização Condicional para produtos antigos) -->
    {product.pros && product.pros.length > 0 && (
      <div class="grid md:grid-cols-2 gap-8 my-20">
        <div class="bg-green-50 dark:bg-green-900/10 p-10 rounded-[2.5rem] border border-green-200 dark:border-green-800/50 shadow-md">
          <h4 class="text-green-700 dark:text-green-400 font-black text-2xl mb-8 flex items-center gap-3">
            <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" /></svg>
            POR QUE COMPRAR
          </h4>
          <ul class="space-y-4 list-none p-0">
            {product.pros.map((pro) => (
              <li class="flex items-start gap-4">
                <span class="flex-shrink-0 w-6 h-6 rounded-full bg-green-200 dark:bg-green-800 text-green-700 dark:text-green-300 flex items-center justify-center font-bold text-sm">+</span>
                <span class="font-medium text-foreground">{pro.replaceAll('*', '')}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="bg-red-50 dark:bg-red-900/10 p-10 rounded-[2.5rem] border border-red-200 dark:border-red-800/50 shadow-md">
          <h4 class="text-red-700 dark:text-red-400 font-black text-2xl mb-8 flex items-center gap-3">
            <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12" /></svg>
            PONTOS NEGATIVOS
          </h4>
          <ul class="space-y-4 list-none p-0">
            {product.cons.map((con) => (
            <li class="flex items-start gap-4">
              <span class="flex-shrink-0 w-6 h-6 rounded-full bg-red-200 dark:bg-red-800 text-red-700 dark:text-red-300 flex items-center justify-center font-bold text-sm">-</span>
              <span class="font-medium text-foreground">{con.replaceAll('*', '')}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
    )}

    <!-- Caixa de Conversão Final (Call To Action) -->
    <div class="border-[4px] border-accent/20 bg-card rounded-[3rem] p-8 md:p-12 mb-20 shadow-xl overflow-hidden relative">
       <div class="absolute top-0 right-0 w-64 h-64 bg-accent/5 rounded-full blur-3xl -mr-20 -mt-20"></div>
       <div class="relative z-10 text-center md:text-left flex flex-col md:flex-row items-center gap-10">
          <div class="w-48 h-48 flex-shrink-0 bg-background rounded-full p-4 shadow-inner group/img relative overflow-hidden transition-all hover:ring-4 hover:ring-primary/20 cursor-pointer">
             <a href={product.amazonUrl} target="_blank" rel="nofollow sponsored" aria-label={`Comprar ${product.name} na Amazon`}>
               <img src={product.image} alt={product.name} class="w-full h-full object-contain mix-blend-multiply dark:mix-blend-normal transition-transform duration-500 group-hover/img:scale-110" loading="lazy" />
             </a>
          </div>
          <div class="flex-1">
             <h3 class="text-3xl font-black mb-4">Vale a pena o investimento?</h3>
             <p class="text-muted-foreground text-lg mb-8 leading-relaxed">
               A <strong class="text-foreground">{product.name}</strong> entrega um equilíbrio incrível de funcionalidades de ponta com confiabilidade de longo prazo. {product.verdict.replaceAll('*', '')}
             </p>
              <div class="mb-4 text-center md:text-left">
                <span class="text-xs font-black uppercase tracking-[0.2em] text-muted-foreground">OFERTAS CONFIÁVEIS ENCONTRADAS:</span>
              </div>
              <div class="grid grid-cols-2 gap-3 sm:gap-4">
                <a href={product.mlUrl} target="_blank" rel="nofollow noopener" class="bg-[#FFE600] text-[#2d3277] flex flex-col items-center justify-center gap-1.5 font-black p-3 sm:p-4 rounded-xl hover:scale-105 transition-transform shadow-lg">
                   <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 48 48" class="text-black sm:w-7 sm:h-7"><ellipse cx="24" cy="24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" rx="19.5" ry="12.978"/><path fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="M9.704 15.53a20.8 20.8 0 0 0 6.386 1.866a23 23 0 0 0 4.546-.773"/><path fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="M38.882 15.614a8.6 8.6 0 0 1-5.165 1.485c-3.335 0-6.225-2.199-9.215-2.199c-2.668 0-7.189 4.373-7.189 5.164s1.31 1.26 2.372.74c.621-.303 3.31-2.914 5.484-2.914s9.219 7.136 9.857 7.806c.989 1.038-.926 3.274-2.149 2.05s-3.41-3.162-3.41-3.162"/><path fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="M43.4 22.683a24 24 0 0 0-8.547 2.692m-2.273 2.081c.989 1.037-.926 3.273-2.149 2.05s-2.581-2.513-2.581-2.513"/><path fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="M30.135 29.215c.988 1.037-.927 3.273-2.15 2.05s-2.025-1.962-2.025-1.962"/><path fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="M24.202 31.316a2.31 2.31 0 0 0 3.648-.186"/><path fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2.5" stroke-linejoin="round" d="M24.202 31.316c.53-.697.49-3.182-2.244-2.688c.642-1.219.066-3.146-2.388-2.01a1.69 1.69 0 0 0-3.146-.658a1.455 1.455 0 0 0-2.8-.28c-.544 1.104.296 3.096 2.092 1.976c-.182 1.944.84 2.537 2.684 1.78c.099 1.91 1.367 1.745 2.273 1.3a1.938 1.938 0 0 0 3.529.58"/><path fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="M4.67 22.279a18.3 18.3 0 0 1 9.064 3.214"/></svg>
                   <span class="text-[10px] sm:text-xs text-center leading-tight">MERCADO<br>LIVRE</span>
                </a>
                <a href={product.amazonUrl} target="_blank" rel="nofollow noopener" class="bg-[#FF9900] text-black flex flex-col items-center justify-center gap-1.5 font-black p-3 sm:p-4 rounded-xl transition-colors hover:bg-[#E68A00]">
                   <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" class="text-black sm:w-7 sm:h-7"><path fill="currentColor" d="M21.997 18.23c0 .727-.405 2.127-1.315 2.896c-.182.14-.364.061-.284-.143c.265-.648.871-2.147.587-2.492c-.201-.262-1.031-.242-1.739-.182c-.323.041-.607.06-.827.105c-.204.016-.245-.163-.041-.303a3.1 3.1 0 0 1 .87-.428c1.15-.344 2.479-.137 2.67.083c.036.042.079.16.079.463m-1.922 1.294a7 7 0 0 1-.829.55c-2.122 1.275-4.871 1.943-7.258 1.943c-3.843 0-7.28-1.417-9.888-3.788c-.224-.182-.039-.446.223-.303c2.81 1.64 6.288 2.632 9.888 2.632c2.266 0 4.708-.424 7.035-1.336c.163-.061.345-.144.504-.202c.367-.165.69.242.325.504m-6.17-11.03c0-1.041.042-1.654-.303-2.18c-.306-.433-.833-.693-1.569-.652c-.798.044-1.655.567-1.873 1.526c-.043.22-.171.436-.437.483l-2.435-.31c-.174-.04-.439-.173-.352-.521C7.459 4.088 9.81 3.129 12.034 3h.522c1.22 0 2.788.349 3.791 1.264c1.217 1.136 1.087 2.662 1.087 4.32v3.927c0 1.178.478 1.7.958 2.314c.13.219.175.477-.044.655a78 78 0 0 1-1.917 1.654c-.175.133-.489.147-.61.045c-.77-.645-.958-1.003-1.435-1.658c-.83.871-1.527 1.352-2.356 1.613a7 7 0 0 1-1.784.216c-2.09 0-3.745-1.303-3.745-3.88c0-2.049 1.09-3.442 2.7-4.101c1.61-.66 3.95-.87 4.704-.874m-.477 5.192c.52-.872.477-1.586.477-3.185c-.652 0-1.306.045-1.871.178c-1.045.303-1.875.96-1.875 2.355c0 1.09.568 1.832 1.526 1.832q.198 0 .348-.045c.67-.186 1.088-.522 1.395-1.135"/></svg>
                   <span class="text-[10px] sm:text-xs text-center leading-tight">VER NA<br>AMAZON</span>
                </a>
              </div>
          </div>
       </div>
    </div>

    <!-- Review Schema Automático (Rich Snippet) -->
    <script type="application/ld+json" set:html={schemaJson} />
      </article>

      <!-- Seção de FAQ (SEO) -->
      <FAQxSchema faqs={entry.data.faqs} title="Dúvidas Frequentes" />
    </div>

    <!-- Barra Lateral (Sidebar Promovida Direita no Desktop) -->
    <aside class="w-full lg:w-[340px] xl:w-[380px] flex-shrink-0 space-y-8 mt-12 lg:mt-0 relative">
      <SidebarOfferWidget excludeId={product.id} limit={2} title="🔥 Ofertas Especiais" />
    </aside>
  </div>

  <!-- Artigos Recentes (Largura total abaixo do Review) -->
  <RecentArticles excludeSlug={product.reviewUrl} />

  <!-- Floating Action Button (FAB) -->
  <button id="btn-ranking-fab" class="fixed bottom-6 right-4 sm:right-6 lg:right-8 z-40 bg-gradient-to-tr from-emerald-500 to-emerald-400 text-black rounded-full w-14 h-14 shadow-[0_10px_40px_rgba(0,0,0,0.5)] flex items-center justify-center hover:scale-105 active:scale-95 transition-transform animate-[bounce_4s_ease-in-out_infinite]" aria-label="Ver Ranking Completo">
     <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 6h16M4 12h16M4 18h7" /></svg>
     <!-- Selo/Notification badge -->
     <span class="absolute -top-1 -right-1 bg-red-600 shadow-sm shadow-red-500/50 text-white text-[9px] font-black px-1.5 py-0.5 rounded-full border border-black/20">TOP 5</span>
  </button>

  <!-- Full Screen Modal Hero (Alternativa 2) -->
  <div id="ranking-modal" class="fixed inset-0 z-[100] bg-black/95 backdrop-blur-3xl transform translate-y-full transition-transform duration-500 ease-[cubic-bezier(0.32,0.72,0,1)] flex flex-col h-[100dvh]">
     
     <!-- Modal Header -->
     <div class="flex items-center justify-between px-6 py-5 border-b border-white/10 shrink-0 bg-black/60 sticky top-0 z-10">
        <div class="flex flex-col">
           <h3 class="text-xl font-black text-white uppercase tracking-wider flex items-center gap-2">
               Top Escolhas 2026
           </h3>
           <p class="text-xs text-white/50">Ranking completo de fechaduras</p>
        </div>
        <button id="btn-close-modal" class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center text-white hover:bg-white/20 active:scale-90 transition-all">
           <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12" /></svg>
        </button>
     </div>
     
     <!-- Scrollable Content -->
     <div class="flex-1 overflow-y-auto px-4 py-6 overscroll-contain" style="scrollbar-width: none;">
        <div class="max-w-md mx-auto w-full">
           <ul class="flex flex-col gap-4 pb-20">
              {products.slice().sort((a, b) => a.rank - b.rank).map((p) => (
                 <li>
                    <a href={p.reviewUrl} class={`flex flex-col p-4 rounded-3xl border transition-all ${p.id === product.id ? 'bg-emerald-500/10 border-emerald-500/50 shadow-lg shadow-emerald-500/20' : 'bg-neutral-900/60 border-white/10 hover:bg-neutral-800'}`}>
                       <div class="flex gap-4">
                           <div class="w-20 h-20 bg-white rounded-2xl flex items-center justify-center p-2 shrink-0 border border-white/10">
                               <img src={p.image} alt={p.name} class="w-full h-full object-contain" loading="lazy" />
                           </div>
                           <div class="flex-1 flex flex-col justify-center min-w-0">
                               <div class="text-[10px] font-black text-white/40 uppercase tracking-widest mb-1 flex items-center gap-2">
                                   <span class={`text-lg leading-none ${p.id === product.id ? 'text-emerald-400' : 'text-white/80'}`}>#{p.rank}</span> 
                                   {p.id === product.id && <span class="bg-emerald-500 px-2 py-0.5 rounded-full text-[9px] text-black">LENDO AGORA</span>}
                               </div>
                               <h4 class="font-bold text-white text-sm sm:text-base leading-tight truncate">{p.name}</h4>
                               <p class="text-[11px] text-emerald-400 mt-2 font-bold truncate">{p.badge.replaceAll('*', '')}</p>
                           </div>
                       </div>
                    </a>
                 </li>
              ))}
           </ul>
        </div>
     </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const fab = document.getElementById('btn-ranking-fab');
      const modal = document.getElementById('ranking-modal');
      const clsBtn = document.getElementById('btn-close-modal');

      function openModal() {
        if (!modal) return;
        modal.classList.remove('translate-y-full');
        document.body.style.overflow = 'hidden'; 
      }

      function closeModal() {
        if (!modal) return;
        modal.classList.add('translate-y-full');
        document.body.style.overflow = '';
      }

      if(fab) fab.addEventListener('click', openModal);
      if(clsBtn) clsBtn.addEventListener('click', closeModal);
    });
  </script>
</BaseLayout>
