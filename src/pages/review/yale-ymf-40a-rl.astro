---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { products } from "../../lib/products";

const product = products.find(p => p.id === 1)!; // Yale YMF 40A RL

const title = "Review Yale YMF 40A RL: Vale a Pena essa Fechadura Digital em 2026?";
const description = "Análise completa da Fechadura Digital Yale YMF 40A RL: Biometria, Trinco Rolete, Fechamento Suave e integração Zigbee (Yale Connect). Veja se vale o preço premium.";
---

<BaseLayout title={title} description={description}>
  <!-- HERO Premium (Landing Page Vibe) -->
  <section class="relative bg-black pt-24 pb-32 px-4 overflow-hidden rounded-b-[4rem]">
    <!-- Background Decorators -->
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-neutral-800/40 via-black to-black"></div>
    <div class="absolute right-0 top-1/2 w-[500px] h-[500px] bg-blue-500/10 rounded-full blur-[120px] pointer-events-none -translate-y-1/2"></div>
    
    <div class="max-w-6xl mx-auto relative z-10 grid lg:grid-cols-2 gap-12 items-center">
      <div class="text-center lg:text-left">
        <!-- Badge -->
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/10 text-white border border-white/20 text-xs font-black uppercase tracking-[0.2em] mb-6 backdrop-blur-sm shadow-xl">
          <span class="w-2 h-2 rounded-full bg-blue-400 animate-pulse"></span>
          Review Masterclass
        </span>
        
        <!-- H1 Title -->
        <h1 class="text-5xl lg:text-7xl font-black text-white mb-6 leading-tight tracking-tighter" itemprop="name">
          Yale YMF 40A RL<br/><span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-300 to-emerald-400 italic">Trinco Rolete</span>
        </h1>
        
        <p class="text-lg text-white/70 mb-10 max-w-xl mx-auto lg:mx-0 font-medium leading-relaxed" itemprop="description">
          Silêncio absoluto. Acesso biométrico fulminante em centésimos de segundo. Design em aço carbono de altíssima estirpe. Conheça a fechadura imponente que lidera o mercado premium em 2026.
        </p>
        
        <!-- Affiliate Buttons Mobile Standard -->
        <div class="bg-white/5 backdrop-blur-md border border-white/10 p-6 sm:p-8 rounded-3xl inline-block w-full max-w-md shadow-2xl">
           <p class="text-white/80 font-black mb-5 text-sm uppercase tracking-widest text-center">Escolha Onde Comprar:</p>
           <div class="grid grid-cols-2 gap-4">
              <a href={product.mlUrl} target="_blank" rel="nofollow sponsored" class="flex flex-col items-center justify-center gap-2 bg-[#FFE600] text-[#2d3277] font-black p-4 rounded-2xl shadow-lg hover:scale-105 transition-all">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 48 48"><ellipse cx="24" cy="24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" rx="19.5" ry="12.978"/><path fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="M9.704 15.53a20.8 20.8 0 0 0 6.386 1.866a23 23 0 0 0 4.546-.773"/><path fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="M38.882 15.614a8.6 8.6 0 0 1-5.165 1.485c-3.335 0-6.225-2.199-9.215-2.199c-2.668 0-7.189 4.373-7.189 5.164s1.31 1.26 2.372.74c.621-.303 3.31-2.914 5.484-2.914s9.219 7.136 9.857 7.806c.989 1.038-.926 3.274-2.149 2.05s-3.41-3.162-3.41-3.162"/><path fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="M43.4 22.683a24 24 0 0 0-8.547 2.692m-2.273 2.081c.989 1.037-.926 3.273-2.149 2.05s-2.581-2.513-2.581-2.513"/><path fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="M30.135 29.215c.988 1.037-.927 3.273-2.15 2.05s-2.025-1.962-2.025-1.962"/><path fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="M24.202 31.316a2.31 2.31 0 0 0 3.648-.186"/><path fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2.5" stroke-linejoin="round" d="M24.202 31.316c.53-.697.49-3.182-2.244-2.688c.642-1.219.066-3.146-2.388-2.01a1.69 1.69 0 0 0-3.146-.658a1.455 1.455 0 0 0-2.8-.28c-.544 1.104.296 3.096 2.092 1.976c-.182 1.944.84 2.537 2.684 1.78c.099 1.91 1.367 1.745 2.273 1.3a1.938 1.938 0 0 0 3.529.58"/><path fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="M4.67 22.279a18.3 18.3 0 0 1 9.064 3.214"/></svg>
              </a>
              <a href={product.amazonUrl} target="_blank" rel="nofollow sponsored" class="flex flex-col items-center justify-center gap-2 bg-[#FF9900] text-black border border-[#FF9900] hover:bg-[#E68A00] font-black p-4 rounded-2xl hover:scale-105 transition-all">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24"><path fill="currentColor" d="M21.997 18.23c0 .727-.405 2.127-1.315 2.896c-.182.14-.364.061-.284-.143c.265-.648.871-2.147.587-2.492c-.201-.262-1.031-.242-1.739-.182c-.323.041-.607.06-.827.105c-.204.016-.245-.163-.041-.303a3.1 3.1 0 0 1 .87-.428c1.15-.344 2.479-.137 2.67.083c.036.042.079.16.079.463m-1.922 1.294a7 7 0 0 1-.829.55c-2.122 1.275-4.871 1.943-7.258 1.943c-3.843 0-7.28-1.417-9.888-3.788c-.224-.182-.039-.446.223-.303c2.81 1.64 6.288 2.632 9.888 2.632c2.266 0 4.708-.424 7.035-1.336c.163-.061.345-.144.504-.202c.367-.165.69.242.325.504m-6.17-11.03c0-1.041.042-1.654-.303-2.18c-.306-.433-.833-.693-1.569-.652c-.798.044-1.655.567-1.873 1.526c-.043.22-.171.436-.437.483l-2.435-.31c-.174-.04-.439-.173-.352-.521C7.459 4.088 9.81 3.129 12.034 3h.522c1.22 0 2.788.349 3.791 1.264c1.217 1.136 1.087 2.662 1.087 4.32v3.927c0 1.178.478 1.7.958 2.314c.13.219.175.477-.044.655a78 78 0 0 1-1.917 1.654c-.175.133-.489.147-.61.045c-.77-.645-.958-1.003-1.435-1.658c-.83.871-1.527 1.352-2.356 1.613a7 7 0 0 1-1.784.216c-2.09 0-3.745-1.303-3.745-3.88c0-2.049 1.09-3.442 2.7-4.101c1.61-.66 3.95-.87 4.704-.874m-.477 5.192c.52-.872.477-1.586.477-3.185c-.652 0-1.306.045-1.871.178c-1.045.303-1.875.96-1.875 2.355c0 1.09.568 1.832 1.526 1.832q.198 0 .348-.045c.67-.186 1.088-.522 1.395-1.135"/></svg>
              </a>
           </div>
           <p class="text-[10px] mt-4 opacity-50 text-center uppercase tracking-widest">*Valores oscilam diariamente.</p>
        </div>
      </div>
      
      <!-- Premium Hero Image -->
      <div class="relative w-full h-full flex items-center justify-center mt-12 lg:mt-0">
         <img src="https://yale.fbitsstatic.net/img/p/fechadura-digital-ymf-40a-rl-abre-com-biometria-e-senha-trinco-rolete-71543/258411.jpg?w=1000&h=1000" alt="Yale YMF 40A RL Trinco Rolete" class="relative z-10 w-full max-w-[350px] object-contain drop-shadow-[0_20px_50px_rgba(255,255,255,0.15)] transform -rotate-[5deg] hover:rotate-0 hover:scale-105 transition-all duration-700" itemprop="image" />
      </div>
    </div>
  </section>

  <!-- ESPECIFICAÇÕES INFOGRÁFICO (Inspirado no Material Oficial Yale) -->
  <section class="max-w-6xl mx-auto px-4 -mt-20 relative z-20">
    <div class="bg-card border border-border rounded-[2.5rem] p-8 md:p-12 shadow-[0_20px_60px_-15px_rgba(0,0,0,0.1)]">
      <h2 class="text-2xl font-black mb-10 text-center uppercase tracking-widest text-muted-foreground">O que faz dela uma Premium?</h2>
      
      <!-- Grid Oficial de Features -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <!-- Feature 1 -->
        <div class="flex flex-col items-center group">
          <div class="w-20 h-20 bg-secondary/50 rounded-3xl flex items-center justify-center mb-5 text-primary group-hover:bg-primary group-hover:text-primary-foreground transition-colors duration-300">
            <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 11c0 3.517-1.009 6.799-2.753 9.571m-3.44-2.04l.054-.09A13.916 13.916 0 008 11a4 4 0 118 0c0 1.017-.07 2.019-.203 3m-2.118 6.844A21.88 21.88 0 0015.171 17m3.839 1.132c.645-2.266.99-4.659.99-7.132A8 8 0 008 4.07M3 15.364c.64-1.319 1-2.8 1-4.364 0-1.457.39-2.823 1.07-4" /></svg>
          </div>
          <h4 class="font-black text-foreground text-lg">Até 100 Biometrias</h4>
          <p class="text-sm text-muted-foreground mt-1 font-medium">Leitor ultra-rápido (&lt;0.5s)</p>
        </div>

        <!-- Feature 2 -->
        <div class="flex flex-col items-center group">
          <div class="w-20 h-20 bg-secondary/50 rounded-3xl flex items-center justify-center mb-5 text-primary group-hover:bg-primary group-hover:text-primary-foreground transition-colors duration-300">
             <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" /></svg>
          </div>
          <h4 class="font-black text-foreground text-lg">Até 100 Senhas</h4>
          <p class="text-sm text-muted-foreground mt-1 font-medium">Teclado numérico blindado</p>
        </div>

        <!-- Feature 3 -->
        <div class="flex flex-col items-center group">
          <div class="w-20 h-20 bg-secondary/50 rounded-3xl flex items-center justify-center mb-5 text-primary group-hover:bg-primary group-hover:text-primary-foreground transition-colors duration-300">
            <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z" /></svg>
          </div>
          <h4 class="font-black text-foreground text-lg">Guia de Voz</h4>
          <p class="text-sm text-muted-foreground mt-1 font-medium">Áudio Menu em 4 idiomas</p>
        </div>

        <!-- Feature 4 -->
        <div class="flex flex-col items-center group">
          <div class="w-20 h-20 bg-secondary/50 rounded-3xl flex items-center justify-center mb-5 text-primary group-hover:bg-primary group-hover:text-primary-foreground transition-colors duration-300">
             <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>
          </div>
          <h4 class="font-black text-foreground text-lg">App Yale Connect*</h4>
          <p class="text-sm text-muted-foreground mt-1 font-medium">Módulo vendido à parte</p>
        </div>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 gap-8 text-center mt-12 border-t border-border pt-12">
        <!-- Feature 5 -->
        <div class="flex flex-col items-center group">
          <div class="w-20 h-20 bg-secondary/50 rounded-3xl flex items-center justify-center mb-5 text-primary group-hover:bg-primary group-hover:text-primary-foreground transition-colors duration-300">
            <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
          </div>
          <h4 class="font-black text-foreground text-lg">4x Pilhas AA</h4>
          <p class="text-sm text-muted-foreground mt-1 font-medium">Autonomia de 3.600 aberturas</p>
        </div>
        
        <!-- Feature 6 -->
        <div class="flex flex-col items-center group">
          <div class="w-20 h-20 bg-secondary/50 rounded-3xl flex items-center justify-center mb-5 text-primary group-hover:bg-primary group-hover:text-primary-foreground transition-colors duration-300">
             <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4" /></svg>
          </div>
          <h4 class="font-black text-foreground text-lg">Portas Grossas</h4>
          <p class="text-sm text-muted-foreground mt-1 font-medium">Espessura de 35 a 100mm</p>
        </div>
        
        <!-- Feature 7 -->
        <div class="flex flex-col items-center col-span-2 md:col-span-1 group">
          <div class="w-20 h-20 bg-secondary/50 rounded-3xl flex items-center justify-center mb-5 text-primary group-hover:bg-primary group-hover:text-primary-foreground transition-colors duration-300">
             <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" /></svg>
          </div>
          <h4 class="font-black text-foreground text-lg">Chave Mecânica</h4>
          <p class="text-sm text-muted-foreground mt-1 font-medium">Acesso de segurança extrema</p>
        </div>
      </div>
      
      <!-- Detalhes do Cilindro/Biometria Ocultos em Grid -->
      <div class="grid sm:grid-cols-2 gap-4 mt-12 bg-secondary/20 rounded-[2rem] p-4">
         <div class="rounded-3xl border border-border bg-card p-4 flex items-center justify-center overflow-hidden">
             <img src="/images/yale-ymf40a/img_1.webp" alt="Chave Mecânica de Emergência Oculta" class="max-h-[180px] object-contain hover:scale-110 transition-transform duration-500" />
         </div>
         <div class="rounded-3xl border border-border bg-card p-4 flex items-center justify-center overflow-hidden">
             <img src="/images/yale-ymf40a/img_2.webp" alt="Sensor de Biometria Super Rápido Yale" class="max-h-[180px] object-contain hover:scale-110 transition-transform duration-500" />
         </div>
      </div>
    </div>
  </section>

  <article class="mx-auto max-w-4xl px-4 py-16" itemscope itemtype="https://schema.org/Product">
    
    <h2 class="text-3xl font-black mt-8 mb-8 uppercase tracking-widest text-primary">Biometria Absurda e Fechos Suaves</h2>
    <div class="prose prose-neutral dark:prose-invert max-w-none text-lg">
      <p class="font-medium text-xl leading-relaxed">
        Seja para modernizar uma porta pivotante espetacular na entrada de casa, ou equipar uma porta de escritório de alto nível. A <strong>Fechadura Digital Yale YMF 40A RL</strong> é a prova final de que nem todas as fechaduras nasceram iguais. Mas a grande pergunta é: <em class="text-primary font-bold">Vale a pena o preço exorbitante?</em>
      </p>

      <p>
        Nesta revisão técnica da equipe Fechadura Biométrica Brasil, destrinchamos a versão <strong class="text-foreground">RL (Trinco Rolete)</strong> deste monstro da tecnologia. O grande apelo por trás da sigla RL é o fim do incômodo de bater porta.
      </p>

      <!-- Pain and Solution Callout -->
      <div class="my-12 bg-card border-l-4 border-primary p-8 rounded-r-3xl shadow-sm">
        <h3 class="font-black text-2xl mb-4 flex items-center gap-3">
           <svg class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
           O Fim da Porta Batendo (O Segredo do Trinco Rolete)
        </h3>
        <p class="text-muted-foreground m-0">
          Fechaduras normais utilizam linguetas chanfradas brutais que, quando você empurra a porta contra o batente (especialmente portas pesadas de madeira maciça ou pivotantes largas), causam aquele ruído alto e exigem força repetitiva. **O Trinco Rolete da YMF 40A age feito um rolamento liso:** ao encostar a porta suavemente no batente, a esfera do rolete desliza sem ruído, e o sensor trava pino magnético instantaneamente de modo silencioso e automático. **Zero barulho. Zero esforço. 100% de classe.**
        </p>
      </div>

      <h2 class="text-3xl font-black mt-16 mb-6">Integração Smart Home: O Hub Zigbee e Yale Connect</h2>
      <p>
        A fechadura Yale YMF 40A RL por padrão (Out of the Box) funciona como uma rainha fechada na sua biometria, senha e Chaves. Mas se você quiser plugar ela no Matrix, você tem que adquirir separadamente o **Módulo Zigbee** e **Hub Yale Connect**. Ao adquirir isso e colocar o chip na placa traseira (atrás das pilhas), você desbloqueia habilidades completas de automação: abertura por Alexa, relatórios de acesso no celular em tempo real e abertura via rede mundial (4G / Wi-Fi).
      </p>

      <!-- Pros and cons Visual Block -->
      <div class="grid md:grid-cols-2 gap-8 my-16">
        <div class="bg-green-500/10 p-8 rounded-3xl border border-green-500/20 shadow-sm">
          <h4 class="text-green-600 font-black mb-6 flex items-center gap-2 text-xl">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
            OS PRÓS
          </h4>
          <ul class="text-sm space-y-4 list-none p-0 font-medium">
            {product.pros.map(pro => <li class="flex items-start gap-2"><strong class="text-green-600 shrink-0 mt-0.5">+</strong> <span class="leading-snug">{pro}</span></li>)}
          </ul>
        </div>
        
        <div class="bg-red-500/10 p-8 rounded-3xl border border-red-500/20 shadow-sm">
          <h4 class="text-red-500 font-black mb-6 flex items-center gap-2 text-xl">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12" /></svg>
            OS CONTRAS
          </h4>
          <ul class="text-sm space-y-4 list-none p-0 font-medium text-muted-foreground">
            {product.cons.map(con => <li class="flex items-start gap-2"><strong class="text-red-500 shrink-0 mt-0.5">-</strong> <span class="leading-snug">{con}</span></li>)}
          </ul>
        </div>
      </div>

    </div>
  </article>

   <!-- Trust Schema -->
   <script type="application/ld+json">
