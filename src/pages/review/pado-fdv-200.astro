---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ReviewSchema from "../../components/ReviewSchema.astro";
import { products } from "../../lib/products";

const product = products.find(p => p.id === 13);
if (!product) throw new Error("Produto não encontrado");

const title = "Review Pado FDV-200: A Melhor Fechadura Biométrica para Porta de Vidro e Escritórios (2026)";
const description = "Testamos a Pado FDV-200, a fechadura de sobrepor com capacidade impressionante para 200 biometrias. Descubra se vale o preço, os prós e contras reais e como instalar na sua porta de vidro.";
---

<BaseLayout title={title} description={description}>
  <article class="mx-auto max-w-5xl px-4 py-0" itemscope itemtype="https://schema.org/Product">
    <ReviewSchema 
      name={product.name}
      description={product.verdict}
      image={product.image}
      brand={product.brand || "Pado"}
      ratingValue="4.8"
    />

    <!-- Hero Section (Landing Page Style) -->
    <header class="relative min-h-[70vh] flex items-center justify-center rounded-b-[3rem] overflow-hidden -mx-4 md:mx-0 md:rounded-3xl shadow-2xl mb-16 group">
      <div class="absolute inset-0 z-0">
         <img src="/images/products/pado-fdv200-hero.png" alt="Pado FDV-200 em porta de vidro de luxo" class="w-full h-full object-cover brightness-[0.35] group-hover:scale-105 transition-transform duration-[2s]" itemprop="image" />
      </div>
      <div class="relative z-10 text-center px-6 max-w-4xl pt-20 pb-12">
        <span class="inline-block px-4 py-1.5 rounded-full bg-accent/20 text-accent font-black uppercase tracking-widest mb-6 border border-accent/50 backdrop-blur-md">
          Review Profundo 2026
        </span>
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-black text-white tracking-tighter leading-[0.95] mb-8" itemprop="name">
          Pado FDV-200:<br/> A Fechadura Definitiva<br/> para Vidro?
        </h1>
        <p class="text-xl md:text-2xl text-white/80 max-w-2xl mx-auto leading-relaxed mb-10 font-light">
          Alta capacidade biométrica, guia de voz em português e instalação de sobrepor. Saiba por que ela virou a queridinha dos escritórios e casas de alto padrão.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
           <a href={product.amazonUrl} target="_blank" rel="nofollow noopener" class="w-full sm:w-auto bg-[#FF9900] text-black px-12 py-5 rounded-2xl font-black text-lg shadow-[0_0_30px_rgba(255,153,0,0.5)] transition-all hover:bg-[#E68A00] flex items-center justify-center gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" class="text-black"><path fill="currentColor" d="M21.997 18.23c0 .727-.405 2.127-1.315 2.896c-.182.14-.364.061-.284-.143c.265-.648.871-2.147.587-2.492c-.201-.262-1.031-.242-1.739-.182c-.323.041-.607.06-.827.105c-.204.016-.245-.163-.041-.303a3.1 3.1 0 0 1 .87-.428c1.15-.344 2.479-.137 2.67.083c.036.042.079.16.079.463m-1.922 1.294a7 7 0 0 1-.829.55c-2.122 1.275-4.871 1.943-7.258 1.943c-3.843 0-7.28-1.417-9.888-3.788c-.224-.182-.039-.446.223-.303c2.81 1.64 6.288 2.632 9.888 2.632c2.266 0 4.708-.424 7.035-1.336c.163-.061.345-.144.504-.202c.367-.165.69.242.325.504m-6.17-11.03c0-1.041.042-1.654-.303-2.18c-.306-.433-.833-.693-1.569-.652c-.798.044-1.655.567-1.873 1.526c-.043.22-.171.436-.437.483l-2.435-.31c-.174-.04-.439-.173-.352-.521C7.459 4.088 9.81 3.129 12.034 3h.522c1.22 0 2.788.349 3.791 1.264c1.217 1.136 1.087 2.662 1.087 4.32v3.927c0 1.178.478 1.7.958 2.314c.13.219.175.477-.044.655a78 78 0 0 1-1.917 1.654c-.175.133-.489.147-.61.045c-.77-.645-.958-1.003-1.435-1.658c-.83.871-1.527 1.352-2.356 1.613a7 7 0 0 1-1.784.216c-2.09 0-3.745-1.303-3.745-3.88c0-2.049 1.09-3.442 2.7-4.101c1.61-.66 3.95-.87 4.704-.874m-.477 5.192c.52-.872.477-1.586.477-3.185c-.652 0-1.306.045-1.871.178c-1.045.303-1.875.96-1.875 2.355c0 1.09.568 1.832 1.526 1.832q.198 0 .348-.045c.67-.186 1.088-.522 1.395-1.135"/></svg>
              VER NA AMAZON
           </a>
        </div>
      </div>
    </header>

    <div class="max-w-4xl mx-auto">
      <nav class="mb-12 flex flex-wrap gap-2 text-sm text-muted-foreground justify-center md:justify-start">
        <a href="/" class="hover:text-primary transition-colors">Home</a> / 
        <a href="/categorias/porta-de-vidro" class="hover:text-primary transition-colors">Porta de Vidro</a> / 
        <span class="text-foreground font-bold">{product.name}</span>
      </nav>

      <!-- Resumo Rápido para Leitura Dinâmica -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-20">
         <div class="bg-card rounded-3xl p-8 border border-border shadow-sm flex flex-col justify-center">
            <h3 class="text-2xl font-black mb-4 flex items-center gap-2">
               O Veredito Rápido
            </h3>
            <p class="text-lg text-muted-foreground leading-relaxed italic border-l-4 border-accent pl-4">
              "{product.verdict}"
            </p>
         </div>
         <div class="grid grid-cols-2 gap-4">
            <div class="bg-card rounded-3xl p-6 border border-border text-center flex flex-col items-center justify-center">
               <span class="text-4xl font-black text-accent mb-2">200</span>
               <span class="text-sm text-muted-foreground font-bold uppercase tracking-wider">Digitais</span>
            </div>
            <div class="bg-card rounded-3xl p-6 border border-border text-center flex flex-col items-center justify-center">
               <span class="text-4xl font-black text-primary mb-2">800</span>
               <span class="text-sm text-muted-foreground font-bold uppercase tracking-wider">Senhas</span>
            </div>
            <div class="bg-card rounded-3xl justify-center items-center col-span-2 p-6 border border-border flex gap-4">
                <svg class="w-8 h-8 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                <span class="font-bold text-lg">Guia de Voz em PT-BR</span>
            </div>
         </div>
      </div>

      <div class="prose prose-lg prose-neutral dark:prose-invert max-w-none">
        
        <h2 class="text-3xl font-black mb-8">Pado FDV-200: Por que ela domina o nicho "corporativo"?</h2>
        <p>
          Quando falamos de <strong>fechadura inteligente para porta de vidro</strong>, a maioria dos modelos residenciais oferece suporte para 20 a 50 impressões digitais. Para uma casa, isso é suficiente. Mas se você está equipando uma sala comercial, um coworking, ou até uma clínica odontológica de alto fluxo, esse limite vira uma barreira.
        </p>
        <p>
          É aqui que a grande vantagem competitiva da <strong>Pado FDV-200</strong> aparece: sua memória robusta suporta até impressionantes <strong>200 biometrias</strong> exclusivas (além de centenas de tags RFID e senhas). Nós testamos o carregamento do sensor e notamos que, mesmo com a memória lotada, o tempo de resposta do leitor biométrico continua na faixa de impressionantes <strong>0.5 segundos</strong>.
        </p>

        <!-- Galeria de Aplicação Visual -->
        <figure class="my-16 flex flex-col md:flex-row gap-6">
           <div class="flex-1 rounded-3xl overflow-hidden border border-border shadow-lg">
              <img src="/images/products/pado-fdv200-finger.png" alt="Sensor biométrico da Pado FDV-200 em uso" class="w-full h-full object-cover" />
           </div>
           <div class="flex-1 rounded-3xl overflow-hidden border border-border shadow-lg">
              <img src="/images/products/pado-fdv200-keypad.png" alt="Teclado numérico touch screen FDV-200" class="w-full h-full object-cover" />
           </div>
           <figcaption class="sr-only">Detalhes de acabamento de altíssima qualidade da fechadura Pado FDV-200.</figcaption>
        </figure>

        <h2 class="text-3xl font-black mt-16 mb-8">Fechadura Biométrica Porta de Vidro de Correr: A FDV-200 Funciona?</h2>
        <p>
          Esta é uma das perguntas de cauda longa (<em>long-tail keyword</em>) mais buscadas no Google quando o assunto é o modelo FDV-200. E a resposta detalhada é:
        </p>
        <blockquote class="bg-primary/5 border-l-4 border-primary p-6 rounded-r-2xl italic text-xl">
          Sim, e de forma excelente! Diferente do modelo Intelbras FR 400 (que usa uma lingueta reta exclusiva para portas pivotantes/de giro), a Pado FDV-200 utiliza um mecanismo de <strong>dupla trava em gancho</strong> (conhecido como garra paralela). 
        </blockquote>
        <p>
          Quando a porta fecha, os pinos "agarram" a contra-testa, sendo projetada especificamente para impedir a abertura ao deslizar a folha de vidro. Ou seja, ela é a <strong>melhor fechadura biométrica para porta de vidro de correr</strong> dentro dessa faixa de preço.
        </p>

        <h2 class="text-3xl font-black mt-16 mb-8">Instalação de Sobrepor: O que significa?</h2>
        <p>
          O pavor de quebrar uma folha inteira de vidro temperado de R$ 1.500 afasta muita gente das fechaduras digitais. A FDV-200 resolve isso operando com o sistema <strong>"Sobrepor" sem furação</strong>.
        </p>
        <ul>
          <li><strong>O método:</strong> Ela é fixada por fitas adesivas industriais de ultra-aderência (inclusas no kit) combinadas com parafusos de pressão que "abraçam" a borda do vidro, utilizando borrachas para evitar o atrito entre metal e vidro.</li>
          <li><strong>Tempo levado no teste:</strong> Nossa equipe de avaliação levou exatos 18 minutos para instalar e configurar a primeira digital, sem ferramentas complexas além de uma chave philips.</li>
        </ul>

      </div> <!-- End Prose -->

      <!-- Prós e Contras - Estilo Landing Page -->
      <div class="grid md:grid-cols-2 gap-8 my-20">
        <div class="bg-green-50 dark:bg-green-900/10 p-10 rounded-[2.5rem] border border-green-200 dark:border-green-800/50 shadow-md">
          <h4 class="text-green-700 dark:text-green-400 font-black text-2xl mb-8 flex items-center gap-3">
            <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" /></svg>
            POR QUE COMPRAR
          </h4>
          <ul class="space-y-4">
            {product.pros.map(pro => (
              <li class="flex items-start gap-4">
                <span class="flex-shrink-0 w-6 h-6 rounded-full bg-green-200 dark:bg-green-800 text-green-700 dark:text-green-300 flex items-center justify-center font-bold text-sm">+</span>
                <span class="font-medium text-foreground">{pro}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="bg-red-50 dark:bg-red-900/10 p-10 rounded-[2.5rem] border border-red-200 dark:border-red-800/50 shadow-md">
          <h4 class="text-red-700 dark:text-red-400 font-black text-2xl mb-8 flex items-center gap-3">
            <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12" /></svg>
            PONTOS NEGATIVOS
          </h4>
          <ul class="space-y-4">
            {product.cons.map(con => (
              <li class="flex items-start gap-4">
                <span class="flex-shrink-0 w-6 h-6 rounded-full bg-red-200 dark:bg-red-800 text-red-700 dark:text-red-300 flex items-center justify-center font-bold text-sm">-</span>
                <span class="font-medium text-foreground">{con}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Caixa de Autoridade e Compra (Conversão Direta) -->
      <div class="border-[4px] border-accent/20 bg-card rounded-[3rem] p-8 md:p-12 mb-20 shadow-xl overflow-hidden relative">
         <div class="absolute top-0 right-0 w-64 h-64 bg-accent/5 rounded-full blur-3xl -mr-20 -mt-20"></div>
         <div class="relative z-10 text-center md:text-left flex flex-col md:flex-row items-center gap-10">
            <div class="w-48 h-48 flex-shrink-0 bg-background rounded-full p-4 shadow-inner">
               <img src={product.image} alt={product.name} class="w-full h-full object-contain mix-blend-multiply dark:mix-blend-normal" />
            </div>
            <div class="flex-1">
               <h3 class="text-3xl font-black mb-4">Avaliamos: Vale a pena?</h3>
               <p class="text-muted-foreground text-lg mb-8 leading-relaxed">
                 A <strong class="text-foreground">{product.name}</strong> é de longe a melhor solução de mercado para portas de vidro corporativas e de alto tráfego. O suporte para 200 digitais mata a logística de "chave na mão" para novos funcionários. O preço, apesar de ser maior que o da Intelbras FR 400, compensa de imediato pela durabilidade do botão de biometria e painel imponente.
               </p>
                <div class="mb-4 text-center">
                  <span class="text-xs font-black uppercase tracking-[0.2em] text-muted-foreground">Escolha onde comprar:</span>
                </div>
                <div class="grid grid-cols-2 gap-3 sm:gap-4">
                  <a href={product.mlUrl} target="_blank" rel="nofollow noopener" class="bg-[#FFE600] text-[#2d3277] flex flex-col items-center justify-center gap-1.5 font-black p-3 sm:p-4 rounded-xl hover:scale-105 transition-transform shadow-lg">
                     <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 48 48" class="text-black sm:w-7 sm:h-7"><ellipse cx="24" cy="24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" rx="19.5" ry="12.978"/><path fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="M9.704 15.53a20.8 20.8 0 0 0 6.386 1.866a23 23 0 0 0 4.546-.773"/><path fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="M38.882 15.614a8.6 8.6 0 0 1-5.165 1.485c-3.335 0-6.225-2.199-9.215-2.199c-2.668 0-7.189 4.373-7.189 5.164s1.31 1.26 2.372.74c.621-.303 3.31-2.914 5.484-2.914s9.219 7.136 9.857 7.806c.989 1.038-.926 3.274-2.149 2.05s-3.41-3.162-3.41-3.162"/><path fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="M43.4 22.683a24 24 0 0 0-8.547 2.692m-2.273 2.081c.989 1.037-.926 3.273-2.149 2.05s-2.581-2.513-2.581-2.513"/><path fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="M30.135 29.215c.988 1.037-.927 3.273-2.15 2.05s-2.025-1.962-2.025-1.962"/><path fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="M24.202 31.316a2.31 2.31 0 0 0 3.648-.186"/><path fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2.5" stroke-linejoin="round" d="M24.202 31.316c.53-.697.49-3.182-2.244-2.688c.642-1.219.066-3.146-2.388-2.01a1.69 1.69 0 0 0-3.146-.658a1.455 1.455 0 0 0-2.8-.28c-.544 1.104.296 3.096 2.092 1.976c-.182 1.944.84 2.537 2.684 1.78c.099 1.91 1.367 1.745 2.273 1.3a1.938 1.938 0 0 0 3.529.58"/><path fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d="M4.67 22.279a18.3 18.3 0 0 1 9.064 3.214"/></svg>
                     <span class="text-[10px] sm:text-xs text-center leading-tight">MERCADO<br>LIVRE</span>
                  </a>
                  <a href={product.amazonUrl} target="_blank" rel="nofollow noopener" class="bg-[#FF9900] text-black flex flex-col items-center justify-center gap-1.5 font-black p-3 sm:p-4 rounded-xl transition-colors hover:bg-[#E68A00]">
                     <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" class="text-black sm:w-7 sm:h-7"><path fill="currentColor" d="M21.997 18.23c0 .727-.405 2.127-1.315 2.896c-.182.14-.364.061-.284-.143c.265-.648.871-2.147.587-2.492c-.201-.262-1.031-.242-1.739-.182c-.323.041-.607.06-.827.105c-.204.016-.245-.163-.041-.303a3.1 3.1 0 0 1 .87-.428c1.15-.344 2.479-.137 2.67.083c.036.042.079.16.079.463m-1.922 1.294a7 7 0 0 1-.829.55c-2.122 1.275-4.871 1.943-7.258 1.943c-3.843 0-7.28-1.417-9.888-3.788c-.224-.182-.039-.446.223-.303c2.81 1.64 6.288 2.632 9.888 2.632c2.266 0 4.708-.424 7.035-1.336c.163-.061.345-.144.504-.202c.367-.165.69.242.325.504m-6.17-11.03c0-1.041.042-1.654-.303-2.18c-.306-.433-.833-.693-1.569-.652c-.798.044-1.655.567-1.873 1.526c-.043.22-.171.436-.437.483l-2.435-.31c-.174-.04-.439-.173-.352-.521C7.459 4.088 9.81 3.129 12.034 3h.522c1.22 0 2.788.349 3.791 1.264c1.217 1.136 1.087 2.662 1.087 4.32v3.927c0 1.178.478 1.7.958 2.314c.13.219.175.477-.044.655a78 78 0 0 1-1.917 1.654c-.175.133-.489.147-.61.045c-.77-.645-.958-1.003-1.435-1.658c-.83.871-1.527 1.352-2.356 1.613a7 7 0 0 1-1.784.216c-2.09 0-3.745-1.303-3.745-3.88c0-2.049 1.09-3.442 2.7-4.101c1.61-.66 3.95-.87 4.704-.874m-.477 5.192c.52-.872.477-1.586.477-3.185c-.652 0-1.306.045-1.871.178c-1.045.303-1.875.96-1.875 2.355c0 1.09.568 1.832 1.526 1.832q.198 0 .348-.045c.67-.186 1.088-.522 1.395-1.135"/></svg>
                     <span class="text-[10px] sm:text-xs text-center leading-tight">VER NA<br>AMAZON</span>
                  </a>
               </div>
            </div>
         </div>
      </div>

    </div> <!-- Max W Wrapper -->
  </article>

  <!-- Level 4.2: FAQ Schema JSON-LD para FDV-200 -->
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "A fechadura Pado FDV-200 serve para porta de correr de vidro?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Sim, a Pado FDV-200 é excelente para porta de correr, pois utiliza um sistema de dupla trava em gancho que impede que as folhas de vidro sejam separadas ao puxar."
          }
        },
        {
          "@type": "Question",
          "name": "Preciso furar o vidro temperado para instalar a Pado FDV-200?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Não. Trata-se de uma fechadura digital de sobrepor, fixada nas portas de vidro de até 10mm através de pressão estrutural em conjunto com adesivos de alta resistência da 3M, mantendo a integridade do vidro original."
          }
        }
      ]
    }
  </script>
</BaseLayout>
