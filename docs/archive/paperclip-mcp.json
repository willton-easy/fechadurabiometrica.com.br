{
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ]
    },
    "search": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-search"
      ]
    },
    "vercel": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-vercel"
      ]
    },
    "serpapi": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-serpapi"
      ]
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ]
    },
    "firecrawl": {
      "command": "npx",
      "args": [
        "-y",
        "firecrawl-mcp"
      ],
      "env": {
        "FIRECRAWL_API_KEY": "SUA_CHAVE_AQUI"
      }
    }
  },
  "agents": {
    "engenheiro-de-hardware": {
      "model": "gemini-3.1-flash",
      "skills": ["github", "search"]
    },
    "estrategista-seo-2026": {
      "model": "gemini-3.1-flash",
      "skills": ["github", "search"]
    },
    "curador-de-ux-design": {
      "model": "gemini-3.1-flash",
      "skills": ["github", "search", "vercel"]
    },
    "gerente-de-conversao": {
      "model": "gemini-3.1-flash",
      "skills": ["github", "search"]
    },
    "antigravity": {
      "model": "gemini-3.1-flash",
      "skills": ["github", "search"]
    },
    "arquiteto-de-agentes-2026": {
      "model": "gemini-3.1-flash",
      "skills": ["github", "search"]
    }
  }
}
